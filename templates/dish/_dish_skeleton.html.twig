{# dish/_dish_card_skeleton.html.twig #}

{# 
    Skeleton card pour une recette (dish).
    Affiché pendant le chargement des données.
    animate-pulse = effet de chargement visuel.
#}
<div class="card-wrapper p-0 shadow-balanced rounded-xl overflow-hidden animate-pulse">
    
    {# =========================
       SKELETON MODE GRID
       ========================= #}
    <div data-view-mode-target="skeletonGrid" class="block">

        {# Badges gluten / lactose (emplacement en haut à gauche) #}
        <div class="absolute top-4 pl-4 flex gap-2">
            <div class="h-7 w-30 bg-gray-300 rounded"></div>
            <div class="h-7 w-30 bg-gray-300 rounded"></div>
        </div>

        {# Indicateurs des groupes alimentaires (FGP colors) #}
        <div class="list-fgp-color absolute top-14 pl-4 gap-2 flex flex-row">
            <div class="h-3 w-3 bg-gray-300 rounded-lg"></div>
            <div class="h-3 w-3 bg-gray-300 rounded-lg"></div>
        </div>

        {# Bouton favoris (coeur) en haut à droite #}
        <div class="absolute top-4 right-3">
            <div class="bg-gray-300 rounded-full" style="width: 30px; height: 30px"></div>
        </div>

        {# Image principale de la recette #}
        <div class="w-full bg-gray-200 rounded-2xl" style="height: 385px"></div>

        {# Footer contenant normalement le nom de la recette #}
        <div class="absolute bottom-0 w-full p-4 bg-white mt-4 rounded-b-2xl">
            <div class="h-6 w-64 bg-gray-300 rounded"></div>
        </div>

    </div>

    {# =========================
       SKELETON MODE LIST
       ========================= #}
    <div data-view-mode-target="skeletonList" class="hidden">

        {# Badges gluten / lactose #}
        <div class="dish-gluten-lactose absolute top-4 gap-2 flex flex-row">
            <div class="h-6 w-30 bg-gray-300 rounded"></div>
            <div class="h-6 w-30 bg-gray-300 rounded"></div>
        </div>

        {# Indicateurs groupes alimentaires (FGP) #}
        <div class="list-fgp-color absolute top-14 gap-2 flex flex-row">
            <div class="h-3 w-3 bg-gray-300 rounded-lg"></div>
            <div class="h-3 w-3 bg-gray-300 rounded-lg"></div>
        </div>

        {# Bouton favoris #}
        <div class="absolute top-4 right-2">
            <div class="bg-gray-300 rounded-full" style="width: 33px; height: 33px"></div>
        </div>

        {# Conteneur principal de la card en mode liste #}
        <div class="flex w-full rounded-t-xl border-white">

            {# Image de la recette (petite vignette à gauche) #}
            <div class="flex w-full rounded-t-xl border-white overflow-hidden">
                <div class="bg-gray-200 rounded-2xl" style="width: 150px; height: 150px"></div>
            </div>

            {# Bloc description (temps, ingrédients, etc.) #}
            <div class="description w-11-12 h-24 mt-4 ml-auto bg-gray-100 mr-14 rounded-lg"></div>

        </div>

        {# Footer contenant le nom de la recette #}
        <div class="absolute bottom-0 w-full p-4 bg-white mt-4 rounded-b-2xl">
            <div class="h-6 w-64 bg-gray-300 rounded"></div>
        </div>
        
    </div>

</div>