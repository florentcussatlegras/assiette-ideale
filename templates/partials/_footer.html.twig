<footer class="text-center text-surface/75 w-full pt-4 mt-0">

    {# Vérifie si l'utilisateur n'est pas connecté ou si son profil est encore à compléter #}
    {% if app.user is null or (app.user and app.user.firstFillProfile is same as (true)) %}

        {# Conteneur principal des sections du footer #}
        <div class="w-4/5 mx-auto flex flex-col lg:flex-row justify-center md:justify-between">

            {# Section 1 : Engagement environnemental #}
            <div class="flex flex-col items-center gap-2 mb-4 flex-1 mx-auto">
                <div class="flex flex-col gap-4 items-center lg:items-start lg:text-left">
                    <h3 class="flex font-bold text-lg items-center gap-3 pb-0">
                        <svg ...> <!-- SVG représentant un logo écologique --> </svg>
                        <span>
                            {% trans from 'footer' %}footer.environmental_policy{% endtrans %}
                        </span>
                    </h3>
                    <div class="rounded p-2">
                        Engagés pour l’environnement. <br>
                        Nous réduisons notre empreinte numérique et privilégions des pratiques responsables afin de limiter l’impact écologique de notre plateforme.
                    </div>
                </div>
            </div>

            {# Section 2 : Liens pour l'utilisateur connecté #}
            <div class="flex flex-col items-center gap-2 mb-4 flex-1 mx-auto">
                <div class="flex flex-col gap-4 items-center lg:items-start lg:text-left">
                    <h3 class="font-bold text-lg">
                        {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                            {{ app.user.username }}
                        {% endif %}
                    </h3>
                    <ul class="flex flex-col gap-4 items-center lg:items-start">
                        <li>
                            <a href="{{ path('app_homepage') }}" class="flex flex-row gap-2 items-center">
                                <i class="fa fa-home" aria-hidden="true"></i>
                                <span>{% trans from 'footer' %}footer.links.home{% endtrans %}</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_profile_index') }}" class="flex flex-row gap-2 items-center">
                                <svg ...> <!-- SVG icône profil --> </svg>
                                <span>{% trans from 'footer' %}footer.links.my_account{% endtrans %}</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            {# Section 3 : Service client et informations légales #}
            <div class="flex flex-col items-center gap-2 mb-4 flex-1 mx-auto">
                <div class="flex flex-col gap-4 items-center lg:items-start lg:text-left">
                    <h3 class="font-bold text-lg">
                        <a href="#" class="flex flex-row gap-2 items-center">
                            {% trans from 'footer' %}footer.links.customer_service{% endtrans %}
                        </a>
                    </h3>
                    <ul class="flex flex-col gap-4 items-center lg:items-start">
                        <li>
                            <a href="{{ path('app_help') }}" class="flex flex-row gap-2 items-center">
                                {% trans from 'footer' %}footer.links.help_center{% endtrans %}
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_contact') }}" class="flex flex-row gap-2 items-center">
                                {% trans from 'footer' %}footer.links.contact{% endtrans %}
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_terms') }}" class="flex flex-row gap-2 items-center">
                                Termes et conditions
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            {# Section 4 : Logo du site pour grands écrans (XL) #}
            <div class="hidden xl:flex xl:flex-row">
                <div class="flex gap-4">
                    <div class="font-bold text-xl text-light-blue">
                        <svg ...> <!-- Logo SITE NUTRITION --> </svg>
                        SITE NUTRITION
                    </div>
                </div>
            </div>

        </div>

        {# Bas de footer avec copyright #}
        <div class="p-6 mt-4 text-center text-sm">
            <div>Assiette idéale © 2025 Copyright</div>
        </div>

    {% endif %}

</footer>