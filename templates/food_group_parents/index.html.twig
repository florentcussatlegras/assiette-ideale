{% extends "base.html.twig" %}

{% block title %}Groupes alimentaires{% endblock %}

{% block body %}

<div class="container mx-auto py-12">

    {# Titre principal de la page #}
    <h1 class="text-3xl font-bold mb-8">
        Les groupes alimentaires
    </h1>

    {# Grille responsive pour afficher les groupes alimentaires #}
    <div class="responsive-grid gap-6">

        {% for group in groups %}

            {# Chaque pavé est un lien vers la page du groupe #}
            <a href="{{ path('app_food_groups_show', { slug: group.slug }) }}"
               class="rounded-xl shadow-lg p-6 transition transform hover:scale-105 flex flex-col items-center gap-4"
               style="background: linear-gradient(135deg, {{ group.color }}, {{ group.degradedColor }})"
            >

                {# Inclusion du SVG correspondant au groupe, centrée en haut, dimensions paramétrables #}
                {{ include("food_group_parents/svg/#{group.alias|lower}.html.twig", {'width': '150px', 'height': '150px'}, ignore_missing: true) }}

                {# Nom du groupe affiché en bas du pavé, centré et en blanc #}
                <span class="mt-auto text-xl font-bold text-white text-center">
                    {{ group.name }}
                </span>

            </a>

        {% endfor %}

    </div>

</div>

{% endblock %}