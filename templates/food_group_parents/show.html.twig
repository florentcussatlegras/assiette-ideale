{% extends "base.html.twig" %}

{% block title %}{{ group.name }}{% endblock %}

{% block body %}

<div class="py-12">

    {# Inclusion de l’en-tête de page avec titre #}
    {{ include('navigation/_header_page.html.twig', {title: 'Les groupes alimentaires'}) }}

    {# Centrage du contenu principal #}
    <div class="flex justify-center">

        {# Carte principale du groupe alimentaire #}
        <div class="bg-white w-full lg:w-2/3 shadow-balanced rounded-xl p-12">

            {# Lien de retour vers la liste des groupes alimentaires #}
            <a href="{{ path('app_food_groups_index') }}" class="flex gap-2 items-center">
                <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 7L10 12L15 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                Revenir aux groupes
            </a>

            {# En-tête coloré du groupe avec dégradé et SVG illustratif #}
            <div class="mt-6 px-8 py-4 rounded-xl text-white relative border flex flex-row justify-between items-center"
                style="background: linear-gradient(135deg, {{ group.color }}, {{ group.degradedColor }})">
                <h1 class="mb-0">{{ group.name }}</h1>

                {# SVG représentant le groupe, dimensions fixes #}
                {{ include('food_group_parents/svg/' ~ group.alias|lower ~ '.html.twig', {
                    'height': '80px', 'width': '80px'
                }) }}
            </div>

            {# Contenu détaillé du groupe #}
            <div class="my-8">
                {{ group.content|raw|nl2br }}

                {# Fun fact optionnel du groupe #}
                {% if group.funFact is not null %}
                    <div class="bg-yellow-100 text-yellow-800 border-l-4 border-yellow-800 p-4 my-8 rounded-md">
                        {{ group.funFact|raw|nl2br }}
                    </div>
                {% endif %}
            </div>

        </div>

    </div>

</div>

{% endblock %}