{# Conteneur principal de la liste de résultats #}
<div class="flex flex-col relative">

    {# Conteneur des lignes d’aliments, positionné en absolu au-dessus du reste #}
    <div class="flex flex-wrap shadow-md bg-white absolute top-0 w-full z-20" 
         data-loading="addClass(opacity-50)">     
        
        {# Boucle sur les aliments par batch de 2 pour créer des lignes #}
        {% for row in foods|batch(2) %}
            {% for food in row %}
                {# Inclusion du template pour chaque aliment (image, nom, bouton, etc.) #}
                {{ include("dish/_search_row_food.html.twig") }}
            {% endfor %}
        {% else %}
            {# Message affiché si aucun aliment ne correspond à la recherche #}
            <div class="text-lg p-4">
                Aucun aliment ne correspond à "{{ query }}"
            </div>
        {% endfor %}

    </div>
</div>