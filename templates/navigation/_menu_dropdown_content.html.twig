<div>

	{# Section utilisateur (avatar + username) #}
	<div class="flex items-center gap-3 px-7 py-3">

		{# Si l'utilisateur a une photo de profil #}
		{% if app.user.picture is not null %}
			<div class="w-9 h-9 rounded-full overflow-hidden border border-gray-300">

				{# Image avec filtre (ex: LiipImagineBundle) pour générer une miniature #}
				<img class="rounded-full"
				     src="{{ app.user.picturePath|imagine_filter('squared_thumbnail_medium') }}"
				     alt="{{ app.user.username }}"
				     class="w-full h-full object-cover">
			</div>
		{% else %}

			{# Sinon on affiche la première lettre du username (fallback avatar) #}
			<div class="w-9 h-9 flex items-center justify-center rounded-full bg-sky-600 text-white font-semibold text-xl uppercase">
				{{ app.user.username|slice(0,1) }}
			</div>
		{% endif %}

		{# Nom d'utilisateur affiché à côté de l'avatar #}
		<div class="text-lg font-semibold text-sky-600">
			{{ app.user.username }}
		</div>

	</div>

	{# Séparateur visuel #}
	<div class="h-1 bg-gray-200 my-2"></div>

	{# ================= MENU PRINCIPAL ================= #}

	{# Lien vers le dashboard utilisateur #}
	<a href="{{ path('app_dashboard_index') }}" class="menu-item">
		<svg class="menu-icon" viewbox="0 0 24 24" fill="none">
			{# Icône dashboard #}
			<path d="M12 12C12 11.4477 12.4477 11 13 11H19C19.5523 11 20 11.4477 20 12V19C20 19.5523 19.5523 20 19 20H13C12.4477 20 12 19.5523 12 19V12Z" stroke="currentColor" stroke-width="2"></path>
			<path d="M4 5C4 4.44772 4.44772 4 5 4H8C8.55228 4 9 4.44772 9 5V19C9 19.5523 8.55228 20 8 20H5C4.44772 20 4 19.5523 4 19V5Z" stroke="currentColor" stroke-width="2"></path>
			<path d="M12 5C12 4.44772 12.4477 4 13 4H19C19.5523 4 20 4.44772 20 5V7C20 7.55228 19.5523 8 19 8H13C12.4477 8 12 7.55228 12 7V5Z" stroke="currentColor" stroke-width="2"></path>
		</svg>
		<span>Mon espace</span>
	</a>

	{# Lien vers les informations du profil #}
	<a href="{{ path('app_profile_index') }}" class="menu-item">
		<svg class="menu-icon" viewbox="0 0 24 24" fill="none">
			{# Icône utilisateur #}
			<circle cx="12" cy="6" r="4" stroke="currentColor" stroke-width="1.5"></circle>
			<path d="M20 17.5C20 19.9853 20 22 12 22C4 22 4 19.9853 4 17.5C4 15.0147 7.58172 13 12 13C16.4183 13 20 15.0147 20 17.5Z" stroke="currentColor" stroke-width="1.5"></path>
		</svg>
		<span>Mes informations</span>
	</a>

	{# Lien vers les repas du jour #}
	<a href="{{ path('meal_day') }}" class="menu-item">
		<svg class="menu-icon" fill="currentColor">
			{# Icône repas (complexe SVG) #}
		</svg>
		<span>Mes repas du jour</span>
	</a>

	{# Lien vers les repas de la semaine #}
	<a href="{{ path('menu_week_menu') }}" class="menu-item">
		<svg class="menu-icon" fill="none" stroke="currentColor">
			{# Icône calendrier #}
			<path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
		</svg>
		<span>Mes repas de la semaine</span>
	</a>

	{# Lien de déconnexion (désactive Turbo pour éviter les soucis) #}
	<a href="{{ path('app_logout') }}" data-turbo="false" class="menu-item text-red-600 hover:text-red-800">
		<svg class="menu-icon" fill="currentColor">
			{# Icône logout #}
		</svg>
		<span>Déconnexion</span>
	</a>

	{# Séparateur #}
	<div class="h-1 bg-gray-200 my-2"></div>

	{# ================= PARAMÈTRES ================= #}

	{# Lien vers les paramètres du profil avec paramètre "element" #}
	<a href="{{ path('app_profile_edit', {element: 'parameters'}) }}" class="menu-item">
		<svg class="menu-icon" fill="none">
			{# Icône engrenage (settings) #}
		</svg>
		<span>Mes paramètres</span>
	</a>

	{# Ligne fine de séparation #}
	<div class="h-px bg-gray-200 my-2"></div>

	{# ================= AIDE ================= #}

	{# Lien vers la page d'aide #}
	<a href="{{ path('app_help') }}" class="menu-item">
		<svg class="menu-icon" fill="none">
			{# Icône aide / info #}
		</svg>
		<span>Aide</span>
	</a>

</div>