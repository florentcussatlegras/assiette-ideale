{# Container principal du résumé nutritionnel du repas #}
<div
	{{ stimulus_controller('modal-meal-nutrition-summary') }}>

	{# Bouton pour ouvrir le modal nutritionnel #}
	<button {{ stimulus_controller('ripple') }} data-action="click->modal-meal-nutrition-summary#open click->ripple#ripple" class="btn-final-alerts rounded-full bg-gray-100 hover:bg-gray-200 p-3 transition duration-300">
		{% if isFullyBalanced %}
			{# équilibré #}
			<svg class="w-10 h-10 text-green-300" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
			</svg>
		{% else %}
			{% if highest_alert is null %}
				{# pas d'excés #}
				<svg class="w-10 h-10 text-gray-400" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
				</svg>
			{% else %}
				{# excés #}
				<svg class="w-10 h-10" style="color: {{ highest_alert.color }}" fill="none" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2
						           M9 5a2 2 0 002 2h2a2 2 0 002-2
						           M9 5a2 2 0 012-2h2a2 2 0 012 2
						           M10 10l4 4
						           M14 10l-4 4"></path>
				</svg>
			{% endif %}
		{% endif %}
	</button>

	{# Inclusion du modal complet de résumé nutritionnel #}
	{{ include('meals/day/modals/_modal_nutrition_summary.html.twig') }}

</div>
