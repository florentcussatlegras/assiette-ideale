{% extends "base.html.twig" %}

{% block body %}

    <div class="flex h-full w-full items-center justify-center relative" style="background-color: #35B4E8">

        {# Conteneur des deux blocs centrés #}
        <div class="flex items-center gap-12">

            {# Bloc gauche #}
            <div class="p-8 rounded-2xl bg-white flex flex-col items-center justify-center relative" style="width: 500px">

                {# Logo - retour à l'accueil #}
                <a href="{{ path('app_homepage') }}">

                    <div class="flex flex-row font-bold cursor-pointer text-sky-600 text-4xl">
                        <div>Assiette&nbsp;</div>
                        <div>idé<span class="text-lime-600">a</span>le</div>
                    </div>

                </a>

                {# Les contenus #}
                <div class="flex flex-col w-full justify-center items-center bg-white">

                        {% block content %}{% endblock %}

                </div>
                
            </div>

            {# Bloc droit - image illustration présente qu'en mode desktop #}
            <img src={{ asset('images/illustration_foods_security.jpg') }} class="my-hidden lg:flex" width="500px" />

        </div>

</div>

{% endblock %}
