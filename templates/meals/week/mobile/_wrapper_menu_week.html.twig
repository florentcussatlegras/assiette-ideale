{% extends "meals/week/_layout.html.twig" %}

{% block table_menu_week %}

	<div class="flex flex-col">

		<!-- Accordéon principal qui gère l'ouverture/fermeture des jours -->
		<div 
			{{ stimulus_controller('menu-accordion') }} 
			class="flex flex-col tracking-tight text-lg w-full"
		>

			{% for date, day in days %}
				{% set index_row = loop.index0 %}

				<!-- Conteneur d'un jour avec fond et bordure -->
				<div
					class="w-full border-b bg-light-blue text-white" data-menu-accordion-target="container">

					<div class="flex flex-col">

						<div class="relative border">
							
							<!-- Bouton du jour qui ouvre le Slideover avec les détails du jour -->
							<button 
								class="w-full flex flex-col items-center justify-center text-xs md:text-sm uppercase py-3" 
								data-action="sidebar-details-meals#toggleSlideover sidebar-details-meals#setMeals" 
								data-date="{{ date }}"
							>

								{{ day|dayTrans }} <!-- Affiche le jour traduit -->

								{% if day in energyTotalPerDays|keys %}
									<!-- Affiche l'énergie totale du jour si disponible -->
									<span>
										{{ render(path('menu_meals_show_total_energy', { 
											'energyMeals': energyTotalPerDays[day], 
											'highestAlertPerDay': highestAlertPerDay[day],
											sizeIcon: 32, 
											fromMenuWeek: true 
										})) }}
									</span>
								{% else %}
									<!-- Cas où aucun repas n'est présent : énergie à 0 -->
									<div class="flex flex-row items-center gap-4 px-6 pt-2">
										<div class="flex items-end gap-2">
											<span class="text-xl font-semibold leading-none text-white">0</span>
											<span class="text-sm">Kcal</span>
										</div>
									</div>
								{% endif %}
							</button>

							<!-- Flèches accordéon pour ouvrir/fermer le panel -->
							<div
								class="absolute bottom-2 right-2 w-6 h-6 cursor-pointer"
								data-action="click->menu-accordion#toggle"
								data-day="{{ date }}"
							>
								<!-- Flèche vers le bas visible par défaut -->
								<svg
									data-menu-accordion-target="arrowDown"
									data-day-arrow="{{ date }}"
									class="w-6 h-6 block transition-opacity duration-200"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
								</svg>

								<!-- Flèche vers le haut cachée par défaut -->
								<svg
									data-menu-accordion-target="arrowUp"
									data-day-arrow="{{ date }}"
									class="w-6 h-6 my-hidden transition-opacity duration-200"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
								</svg>
							</div>

						</div>

					</dib> <!-- Conteneur du bouton jour -->

					<!-- Panel accordéon pour afficher les repas du jour -->
					<div
						class="day-panel w-full bg-white text-gray-700 overflow-hidden transition-all duration-300 flex-col" 
						data-menu-accordion-target="panel" 
						data-day-panel="{{ date }}"
					>

						<!-- Lien pour voir tous les repas du jour sur une page séparée -->
						<div class="border-gray-200 border-l border-r border-b w-full flex justify-center items-center">
							<a href="{{ path('menu_week_get_meals', {date: date}) }}" class="flex items-center gap-2 group py-2">
								<svg class="w-6 h-6 text-gray-400 hover:text-gray-500 transition-colors duration-200" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">...</svg>
							</a>
						</div>
					
						{% for typeMeal in typeMeals %}
							<!-- Nom du type de repas (ex: Petit-déjeuner, Déjeuner) -->
							<div class="text-base pt-2 pl-2 border-r border-l border-gray-200">{{ typeMeal.frontName }}</div>

							<!-- Conteneur des repas du type correspondant -->
							<div class="pt-2 border-b border-l border-r flex h-full border-gray-200 min-h-16 p-2">
								<div class="flex flex-col justify-start w-full relative pb-2">
									{% if meals[day] is not empty and meals[day][typeMeal.backName] is not empty %}
										<!-- Inclusion du template qui liste tous les repas du type pour ce jour -->
										{{ include("meals/week/_meals_of_a_day.html.twig", {'meals' : meals[day][typeMeal.backName]}) }}
									{% endif %}
								</div>
							</div>

						{% endfor %}
					
					</div> <!-- Fin du panel accordéon -->

				</div> <!-- Fin conteneur jour -->

			{% endfor %}

		</div> <!-- Fin accordéon principal -->

	</div> <!-- Fin container flex -->

{% endblock %}