{% extends "meals/week/_layout.html.twig" %}

{% block table_menu_week %}

    <div class="flex flex-col">

        {# Ligne d'en-tête : affiche les 7 jours de la semaine #}
        <div class="grid grid-cols-7 tracking-tight text-lg ml-5">

            {% for date, day in days %}

                <div class="flex flex-col">

                    {# Bouton du jour : ouvre le panneau latéral avec le détail des repas #}
                    <button 
                        class="flex flex-col items-center text-xs md:text-sm bg-light-blue text-white uppercase justify-center py-2 {% if loop.first %}rounded-tl-2xl{% endif %} {% if loop.last %}rounded-tr-2xl{% endif %}" 
                        style="height:90px"
                        data-action="sidebar-details-meals#toggleSlideover sidebar-details-meals#setMeals"
                        data-date="{{ date }}"
                        data-highest-alert-per-day="{{ highestAlertPerDay[day]|default(null) }}"
                    >

                        {# Nom du jour (traduit via filtre custom) #}
                        {{ day|dayTrans }}

                        {# Affichage du total énergétique du jour si disponible #}
                        {% if day in energyTotalPerDays|keys %}
                            <span>
                                {{ render(path('menu_meals_show_total_energy', { 
                                    'energyMeals': energyTotalPerDays[day],
                                    'highestAlertPerDay': highestAlertPerDay[day],
                                    'sizeIcon': 32,
                                    'fromMenuWeek': true 
                                })) }}
                            </span>
                        {% else %}

                            {# Si aucun repas → énergie = 0 kcal #}
                            <div class="flex flex-row items-center gap-4 px-6 pt-2 bg-light-blue">
                                <div class="flex items-end gap-2">
                                    <span class="text-xl font-semibold leading-none text-white">0</span>
                                    <span class="text-sm">Kcal</span>
                                </div>
                            </div>

                        {% endif %}

                    </button>

                    {# Bouton édition pour modifier les repas du jour #}
                    <div class="border-gray-200 {% if loop.first %}border-l {% endif %}border-r border-b w-full flex justify-center items-center">

                        <a href="{{ path('menu_week_get_meals', {'date': date }) }}" class="flex items-center gap-2 group py-2">
                       
                            {# Icône crayon (édition) #}
                            <svg class="w-6 h-6 text-gray-400 hover:text-gray-500 transition-colors duration-200" viewBox="0 0 24 24" fill="none">
                                ...
                            </svg>
					
                        </a>
                            
                    </div>

                </div>

            {% endfor %}

        </div>
        
        {# Tableau principal contenant les repas par type (petit-déj, déjeuner, dîner...) #}
        <div class="flex flex-col text-sm">

            {% for typeMeal in typeMeals %}

                {# Ligne correspondant à un type de repas #}
                <div class="flex flex-row relative bg-white" style="min-height:180px">

                    {# Nom du type de repas affiché verticalement sur la gauche #}
                    <span style="
                            transform-origin: 0 0;
                            transform: rotate(270deg); 
                            position: absolute;
                            top: 0;
                            left: 0;
                            width: 180px;
                            word-wrap: break-word; 
                            margin-top: 180px;
                            text-align: right;
                            padding-right: 10px">
                            {{ typeMeal.frontName }}
                    </span>

                    {% set index_row = loop.index0 %}

                    {# Grille contenant les 7 jours pour ce type de repas #}
                    <div class="grid grid-cols-7 w-full ml-5 bg-white">

                        {% for date, day in days %}
                
                                {# Si des repas existent pour ce jour et ce type #}
                                {% if meals[day] is not empty and meals[day][typeMeal.backName] is not empty %}

                                    <div class="pt-2 {% if index_row != 4 %}border-b{% endif %} border-gray-200 {% if not loop.last %}border-r{% endif %} {% if loop.first %}border-l{% endif %} flex h-full">

                                        <div class="flex flex-col justify-start w-full relative pb-2">

                                            {# Inclusion de la liste des repas du jour #}
                                            {{ include("meals/week/_meals_of_a_day.html.twig", {
                                                'meals' : meals[day][typeMeal.backName]
                                            }) }}   

                                        </div>

                                    </div>

                                {% else %}

                                    {# Cellule vide si aucun repas #}
                                    <div class="relative border-b border-gray-200 border-r {% if loop.first %}border-l{% endif %} flex items-center justify-center h-full gap-2">
                                        
                                    </div>
                                
                                {% endif %}

                        {% endfor %}

                    </div>
                
                </div>

            {% endfor %}

        </div>

    </div>

{% endblock %}