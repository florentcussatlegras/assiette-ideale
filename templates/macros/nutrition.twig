{#
    Macro Twig : accordion

    Génère un bloc accordéon affichant les informations d'une alerte nutritionnelle
    (énergie, nutriment ou groupe alimentaire).

    Paramètres :
    - title : string
        Titre affiché dans l'entête de l'accordéon.

    - data : object
        Données de l'alerte contenant notamment :
        consumed, recommended, level, etc.

    - suggestion : array
        Tableau des messages de suggestion indexé par :
        'low', 'high', 'well'.

    - valueUnit : string
        Unité de la valeur consommée (ex: g, Kcal).

    - recommendedUnit : string
        Unité de la valeur recommandée.

    - type : string
        Type de donnée affichée :
        - "energy"
        - "nutrient"
        - "fgp" (food group parent)

        Permet de gérer certaines particularités d'affichage.
#}

{% macro accordion(title, data, suggestion, valueUnit, recommendedUnit, type) %}

    {#
        Détermination de la direction de l'alerte :
        - low  : consommation insuffisante
        - high : consommation excessive
        - well : équilibre correct

        Cette direction sert à récupérer le bon message
        dans le tableau "suggestion".
    #}
    {% set direction = data.level.code in constant('App\\Entity\\Alert\\LevelAlert::LOW_ALERTS')
        ? constant('App\\Entity\\Alert\\LevelAlert::LOW_ALERTS_LABEL')
        : data.level.code in constant('App\\Entity\\Alert\\LevelAlert::HIGH_ALERTS')
            ? constant('App\\Entity\\Alert\\LevelAlert::HIGH_ALERTS_LABEL')
            : constant('App\\Entity\\Alert\\LevelAlert::WELL_ALERTS_LABEL')
    %}

    {# Conteneur principal de l'accordéon #}
    <div {{ stimulus_controller('meal-day-report-section') }} class="border-b border-gray-200">

        {# Header de l'accordéon (zone cliquable) #}
        <div
            data-action="click->meal-day-report-section#toggle"
            class="flex justify-between items-center py-2 cursor-pointer hover:bg-gray-100 transition duration-300"
        >

            {# Partie gauche : icône + titre #}
            <div class="flex flex-row items-center gap-2">

                {# Icône avec couleur correspondant au niveau d'alerte #}
                <div class="rounded-full p-2 ml-2" style="background-color: {{ data.level.color }}">

                    {# Si l'équilibre est bon → icône check #}
                    {% if data.level.code is same as(constant('App\\Entity\\Alert\\LevelAlert::BALANCE_WELL')) %}

                        <svg class="w-5 h-5 text-white" fill="currentColor" viewbox="0 0 32 32">
                            <path d="M28.998 8.531l-2.134-2.134c-0.394-0.393-1.030-0.393-1.423 0l-12.795 12.795-6.086-6.13c-0.393-0.393-1.029-0.393-1.423 0l-2.134 2.134c-0.393 0.394-0.393 1.030 0 1.423l8.924 8.984c0.393 0.393 1.030 0.393 1.423 0l15.648-15.649c0.393-0.392 0.393-1.030 0-1.423z"/>
                        </svg>

                    {% else %}

                        {# Sinon → icône warning #}
                        <svg class="text-white w-5 h-5" viewbox="0 0 24 24" fill="currentColor">
                            <path d="M12 5L12 14" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                            <circle cx="12" cy="18.8" r="1.8" fill="currentColor"/>
                        </svg>

                    {% endif %}

                </div>

                {# Titre de la section (ex: protéines, lipides, énergie) #}
                <span>{{ title }}</span>

            </div>

            {# Résumé des quantités consommées / recommandées #}
            <div class="ml-auto mr-6" style="color: {{ data.level.color }}">
                {{ data.consumed|round }}
                {{ valueUnit }}
                /
                {{ data.recommended|round }}
                {{ recommendedUnit }}
            </div>

            {# Icône chevron de l'accordéon #}
            <svg
                data-meal-day-report-section-target="icon"
                class="w-4 h-4 transition-transform duration-300 mr-2"
                fill="none"
                stroke="currentColor"
                viewbox="0 0 24 24"
            >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>

        </div>

        {# Contenu de l'accordéon (caché par défaut) #}
        <div
            data-meal-day-report-section-target="content"
            class="overflow-hidden transition-all duration-300"
            style="height:0px;"
        >

            <div class="pb-4 pt-2 px-8 text-sm text-gray-600">

                {# Message de suggestion adapté au niveau d'alerte #}
                {{ suggestion[direction] }}

                <ul class="list-disc pl-5 space-y-1 ml-6 mt-2">

                    <li>
                        Consommé :
                        {{ data.consumed|round }}
                        {{ valueUnit }}
                    </li>

                    {#
                        Gestion spécifique des Food Group Parents (fgp)
                        Certains groupes peuvent être optionnels
                        et n'ont pas de minimum recommandé.
                    #}
                    {% if type == 'fgp' %}

                        {% if data.isPrincipal %}

                            <li>
                                Recommandé :
                                {{ data.recommended|round }}
                                {{ recommendedUnit }}
                            </li>

                            <li>
                                Niveau :
                                {{ data.level.placeholderText ?? data.level.code }}
                            </li>

                        {% else %}

                            <li>
                                Maximum recommandé :
                                {{ data.recommended|round }}
                                {{ recommendedUnit }}
                            </li>

                            {% if data.level.code is same as(constant('App\\Entity\\Alert\\LevelAlert::BALANCE_WELL')) %}

                                <li>
                                    Ce groupe alimentaire est
                                    <strong>optionnel</strong>.
                                    Il n’existe
                                    <strong>pas de minimum recommandé</strong>,
                                    mais une consommation excessive peut être signalée.
                                </li>

                            {% else %}

                                <li>
                                    Niveau :
                                    {{ data.level.placeholderText ?? data.level.code }}
                                </li>

                            {% endif %}

                        {% endif %}

                    {% else %}

                        {# Cas standard (énergie et nutriments) #}
                        <li>
                            Recommandé :
                            {{ data.recommended|round }}
                            {{ recommendedUnit }}
                        </li>

                        <li>
                            Niveau :
                            {{ data.level.placeholderText ?? data.level.code }}
                        </li>

                    {% endif %}

                </ul>

            </div>

        </div>

    </div>

{% endmacro %}