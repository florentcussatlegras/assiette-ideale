{% extends "base.html.twig" %}

{% block title %}{{ parent() }} - Nos recommandations journalières{% endblock %}

{% block body %}
    
    <div class="py-12">

        {# Inclusion du header de page avec le titre #}
        {{ include('navigation/_header_page.html.twig', {title: 'Nos recommandations journalières'}) }}

        {# Conteneur principal pour les trois blocs : énergie, groupes alimentaires, nutriments #}
        <div class="flex flex-col lg:flex-row gap-4 items-start text-base">

            {# Bloc 1 : Besoin énergétique de l'utilisateur #}
            <div class="w-full lg:w-1/3 bg-white h-auto rounded-xl shadow-balanced">
                              
                {# Titre du bloc #}
                <span class="py-4 flex items-center justify-center font-medium border-b w-full bg-light-blue text-white rounded-t-xl uppercase gap-2">
                    Votre besoin énergétique
                </span>
                
                {# Contenu central : affichage de l'énergie ou options pour la saisir/estimer #}
                <div class="flex items-center justify-center font-bold h-28">

                    <div class="flex flex-col gap-3 items-center text-red-700">
                    
                        {% if app.user.energy %}

                            {# Affichage de la valeur énergétique si disponible #}
                            <span class="text-xl">
                                {{ '%kcal% kCal / %kj% kJ'|replace({"%kcal%": app.user.energy|round, "%kj%": app.user.energyKj|round}) }}
                            </span>

                        {% else %}
                        
                            {# Message si l'énergie n'a pas été saisie #}
                            <div class="text-sm flex flex-col items-center gap-4">

                                {% if app.user.automaticCalculateEnergy is same as(false) %}

                                    <span>Vous n'avez pas indiqué votre besoin énergétique quotitien</span>

                                {% endif %}

                                {% if missingElements|length > 0 %}

                                    {# Affichage des informations manquantes pour calculer l'énergie #}
                                    <p>Il nous manque des informations afin que nous puissions calculer votre besoin energétique journalier:
                                        {{ missingElements|join(',', ' et ') }}
                                        <br/>Merci de compléter ces informations ou 
                                    </p>

                                {% else %}

                                    {# Lien pour estimer automatiquement le besoin énergétique #}
                                    <a href="{{ path('app_energy_estimate') }}" 
                                                class="text-dark-blue text-black p-2 rounded-full">
                                            Laissez l'application estimer mon besoin énergétique
                                    </a>

                                {% endif %}   

                                {# Lien pour saisir manuellement le besoin énergétique #}
                                <div class="flex flex-row text-sm gap-2">
                                    <a href="{{ path('app_profile_edit', {element : constant('App\\Service\\ProfileHandler::ENERGY')}) }}"
                                                class="text-white bg-dark-blue p-2 rounded-full">
                                        Saisir votre besoin
                                    </a> 
                                </div>

                            </div>

                        {% endif %}

                    </div>

                </div>  
                
            </div>

            {# Bloc 2 : Besoins par groupes alimentaires #}
            <div class="w-full lg:w-1/3 bg-white rounded-xl shadow-balanced">
                            
                {# Titre du bloc #}
                <span class="py-4 flex items-center justify-center font-medium border-b w-full bg-light-blue text-white rounded-t-xl uppercase gap-2">
                    Vos besoins par groupes alimentaires
                </span>
                
                {# Liste des groupes alimentaires et des quantités recommandées #}
                <div class="flex items-center justify-center font-bold">

                    <ul class="flex flex-col py-4">
                    
                        {% for fgp, quantity in app.user.recommendedQuantities %}

                            <li class="px-6 py-2 font-medium flex flex-row gap-2 items-start">
                                {# Cercle coloré représentant le groupe alimentaire #}
                                <div class="flex rounded-full w-4 h-4 mt-1" style="background-color: {{ fgp|foodGroupParent.color }}"></div>
                                <div class="flex flex-col">
                                    <span>
                                        {{ fgp|foodGroupParent.name|capitalize }}
                                    </span>
                                    <span class="text-neutral-500 text-sm">
                                        {{ "%s g"|format(quantity) }}
                                    </span>
                                </div>
                            </li>

                        {% endfor %}

                    </ul>

                </div>  
                
            </div>

            {# Bloc 3 : Besoins en nutriments #}
            <div class="w-full lg:w-1/3 bg-white rounded-xl shadow-balanced">
                            
                {# Titre du bloc #}
                <span class="py-4 flex items-center justify-center font-medium border-b w-full bg-light-blue text-white rounded-t-2xl uppercase gap-2">
                    Vos besoins en nutriments
                </span>
                
                {# Inclusion de la liste des nutriments depuis un template séparé #}
                <div class="flex my-2 font-bold justify-center items-center">

                    {{ include('recommendations/nutrient/_list.html.twig') }}

                </div>  
                
            </div>

        </div>

    </div>

{% endblock %}