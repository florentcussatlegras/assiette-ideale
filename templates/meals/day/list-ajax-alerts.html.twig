{# Si aucune alerte n’existe pour cet aliment/plat #}
{% if alerts is empty %}

    {% set text = "Conseillé" %}

    <div 
        class="alert-{{ dishOrFoodId }} flex items-center advice text-sm font-bold w-full cursor-default"
        data-alert-text="{{ text }}"
    >
        <div class="flex items-center justify-center rounded-full bg-green-500 text-white border p-2">
            {# Icône checkmark pour signaler que c’est conseillé #}
            <svg class="text-white w-7 h-7" fill="currentColor" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" stroke="currentColor">
                <path d="M28.998 8.531l-2.134-2.134c-0.394-0.393-1.030-0.393-1.423 0l-12.795 12.795-6.086-6.13c-0.393-0.393-1.029-0.393-1.423 0l-2.134 2.134c-0.393 0.394-0.393 1.030 0 1.423l8.924 8.984c0.393 0.393 1.030 0.393 1.423 0l15.648-15.649c0.393-0.392 0.393-1.030 0-1.423z"></path>
            </svg>
        </div>
    </div>

{# Sinon, il existe une ou plusieurs alertes pour cet aliment/plat #}
{% else %}

    <!-- Bouton pour ouvrir le modal avec les alertes détaillées -->
    <button 
        type="button" 
        data-toggle="modal" 
        data-target="#alertMealModal"
        class="alert-{{ dishOrFoodId }} flex justify-start advice text-sm font-bold w-full text-left cursor-pointer"
        data-action="click->alert-meal-modal#showMessages"
        data-url="{{ path('alert_meal_list', {
            'class': class,
            'dishOrFoodId': dishOrFoodId,
            'isSelected': isSelected|default(0),
            'rankMeal': rankMeal,
            'rankDish': rankDish
        }) }}"
        data-alert-color="{{ alerts.higher_level.color }}"
        data-alert-text="{{ alerts.higher_level.text }}"
    >
        {# Rond coloré indiquant le niveau d’alerte #}
        <span class="rounded-full flex items-center justify-center p-2" style="background-color: {{ alerts.higher_level.color }}">
            <svg class="text-white w-7 h-7" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5L12 14" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M13.8417 18.8417C13.8417 19.8588 13.0171 20.6833 12 20.6833C10.9829 20.6833 10.1583 19.8588 10.1583 18.8417C10.1583 17.8245 10.9829 17 12 17C13.0171 17 13.8417 17.8245 13.8417 18.8417Z" fill="currentColor"></path>
            </svg>
            {# Ici, tu peux éventuellement afficher le texte de l’alerte directement #}
        </span>
    </button>

{% endif %}