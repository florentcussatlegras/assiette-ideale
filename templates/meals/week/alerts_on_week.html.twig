{# Vérifie qu'il existe des groupes alimentaires à afficher #}
{% if fgpLevel is not empty %}

	<div class="box mb-4">
			
		<div class="flex flex-row flex-auto">

			{# Parcourt les niveaux de recommandation (recommended, not_recommended, etc.) #}
			{% for level, fgpIds in fgpLevel %}

				{# Parcourt les groupes alimentaires appartenant à ce niveau #}
				{% for fgpId in fgpIds %}

					{# Récupère l'entité FoodGroupParent correspondante #}
					{% set fgp = object(fgpId, "App\\Entity\\FoodGroup\\FoodGroupParent") %}

					{# Bloc affichant un groupe alimentaire avec sa couleur et son niveau d'alerte #}
					<div style="display:flex; align-items:center; border-left:5px solid {{ fgp.color }}; background-color:#fff; border-bottom:1px solid #dbdbdb; padding: 20px{% if level == 'strongly_not_recommended' or level == 'highly_not_recommended' %}; border-top:1px solid #d74a38; border-bottom:1px solid #d74a38; border-right: #d74a38{% endif %}">
						
						{# Si la consommation est correcte → affichage d'un check vert #}
						{% if level == 'recommended' %}

							<span>{{ include("meals/pictos/check-min.xml.twig", {"color" : "#7a9755"}) }}</span>
							<span style="flex:0.2; padding-left:10px">{{ fgp.name }}</span>

						{% else %}

							{# Sinon → affichage d'une alerte #}
							<span>
								{{ include("meals/pictos/warning.xml.twig") }}
							</span>

							<span style="flex:0.3; padding-left:10px">{{ fgp.name }}</span>

							{# Message d'avertissement selon le niveau de dépassement #}
							{% if level == 'strongly_not_recommended' %}

								<span style="flex: 0.3; margin-left: 20px">
									<span style="padding:0 10px; background-color:#d74a38; color:#fff; font-size:13px">
										Vous en consommez plus du double de la quantité recommandée !
									</span>
								</span>

							{% elseif level == 'highly_not_recommended' %}

								<span style="flex: 0.3; margin-left: 20px; padding:0 10px; color:#d74a38; font-size:13px">
									Vous en consommez beaucoup trop !
								</span>

							{% else %}

								<span style="flex: 0.3; margin-left: 20px; padding:0 10px; color:#d74a38; font-size:13px">
									Vous en consommez trop
								</span>

							{% endif %}

						{% endif %}

					</div>

				{% endfor %}

			{% endfor %}

		</div>

	</div>

{% endif %}