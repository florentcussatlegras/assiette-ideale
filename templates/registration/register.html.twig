{# Hérite du layout principal de la partie sécurité (login/register) #}
{% extends "security/_layout.html.twig" %}

{# Permet de personnaliser le rendu du formulaire dans ce template #}
{% form_theme registerForm _self %}

{% block title %}S'inscrire{% endblock %}

{% block content %}

    {{ form_start(registerForm, {'attr' : {'novalidate' : 'novalidate', 'class': 'security'}}) }}

        {# Affichage des erreurs globales du formulaire #}
        {{ form_errors(registerForm) }}
        
        {# Conteneur des champs avec spacing Tailwind #}
        <div class="mt-8 flex flex-col gap-3 text-sm">

            <div>
                {# Affiche les erreurs du champ email #}
                <span class="text-red-500">{{ form_errors(registerForm.email) }}</span>

                {# Champ email avec placeholder + styles #}
                {{ form_widget(registerForm.email, {
                    'attr': {
                        'placeholder': 'Adresse e-mail',
                        'class': 'block w-full bg-white rounded-lg border border-gray-300 text-gray-900 text-base'
                    }
                }) }}
            </div>

            <div>
                {# Erreurs du champ username #}
                <span class="text-red-500">{{ form_errors(registerForm.username) }}</span>

                {# Champ username #}
                {{ form_widget(registerForm.username, {
                    'attr': {
                        'placeholder': "Nom d'utilisateur",
                        'class': 'block w-full bg-white rounded-lg border border-gray-300 text-gray-900 text-base'
                    }
                }) }}
            </div>

            <div>
                {# Erreurs du mot de passe #}
                <span class="text-red-500">{{ form_errors(registerForm.plainPassword) }}</span>
       
                {# Stimulus controller pour afficher/masquer le mot de passe #}
                <div data-controller="password-visibility" class="relative flex items-center">

                    {# Champ mot de passe #}
                    {{ form_widget(registerForm.plainPassword, {
                        'attr': {
                            'id': 'psw',
                            'placeholder': "Mot de passe",
                            'class': 'block w-full bg-white rounded-lg border border-gray-300 text-gray-900 text-base'
                        }
                    }) }}

                    {# Bouton (œil) pour afficher/masquer le mot de passe #}
                    {{ include('partials/_button_visibility_pwd.html.twig') }}
                </div>

            </div>

        </div>

        {# Section des conditions d'utilisation #}
        <div class="flex flex-col mt-6 text-sm">

            {# Erreurs checkbox conditions #}
            <span class="text-red-500">{{ form_errors(registerForm.terms) }}</span>

            <div class="flex flex-row gap-1">
                <div>
                    {# Checkbox des conditions #}
                    {{ form_widget(registerForm.terms) }}
                </div>
                <div class="mt-1">
                    {{ form_label(registerForm.terms, null, {
                        'label_attr': {'class': 'font-normal'}
                    }) }}
                </div>
            </div>
        </div>

        <div class="button-group text-center mt-4">

            {# Bouton submit #}
            <button type="submit"
                class="text-white bg-sky-600 hover:bg-sky-700 w-full font-bold py-3 text-base cursor-pointer rounded-lg transition duration-300">
                Valider
            </button>

            {# Lien vers la page de connexion #}
            <div class="mt-5 text-sm">
                Déja inscrit? <br>
                <a href="{{ path('app_login') }}"
                   class="text-sky-600 hover:text-sky-700 transition duration-300 text-sm font-semibold">
                    Identifiez-vous
                </a>
            </div>
        </div>

        {# Mention des termes et conditions #}
        <div class="mt-2 text-center text-sm">
			En vous inscrivant, vous acceptez nos
			<br>

            {# Lien vers la page des CGU #}
			<a class="text-sky-600 hover:text-sky-700 hover:text-sky-900 transition duration-300 font-semibold"
               href="{{ path('app_terms') }}">
                Termes et Conditions
            </a>
		</div>

    {# Fin du formulaire (inclut CSRF token automatiquement) #}
    {{ form_end(registerForm) }}

{% endblock %}