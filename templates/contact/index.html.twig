{% extends "base.html.twig" %}

{% block title %}{{ parent() }} - Nous contacter{% endblock %}

{% block body %}

    <div class="py-12">

        {# Header de la page avec titre #}
        {{ include('navigation/_header_page.html.twig', {title: 'Nous écrire'}) }}

        {# Conteneur central du formulaire #}
        <div class="flex justify-center">

            <div class="bg-white w-full lg:w-1/2 shadow-balanced rounded-xl">

                <div class="p-10">

                    {# Début du formulaire de contact #}
                    {{ form_start(formContact, {'attr' : {'novalidate' : 'novalidate'}}) }}

                        <div class="flex flex-col gap-6">

                            {# Champ Email avec label, widget et erreurs #}
                            <div>
                                {{ form_label(formContact.email) }}
                                {{ form_widget(formContact.email) }}
                                <div class="text-red-600 text-sm mt-1">
                                    {{ form_errors(formContact.email) }}
                                </div>
                            </div>

                            {# Champ Sujet (utilise form_row pour tout) #}
                            <div>
                                {{ form_row(formContact.subject) }}
                            </div>

                            {# Champ Message avec label, widget et erreurs #}
                            <div>
                                {{ form_label(formContact.body) }}
                                {{ form_widget(formContact.body) }}
                                <div class="text-red-600 text-sm mt-1">
                                    {{ form_errors(formContact.body) }}
                                </div>
                            </div>

                            {# Bouton d'envoi du formulaire #}
                            <button class="px-4 py-2 rounded-lg bg-light-blue text-white font-semibold">Envoyer</button>

                        </div>

                    {# Fin du formulaire #}
                    {{ form_end(formContact) }}

                </div>

            </div>

        </div>

    </div>

{% endblock %}