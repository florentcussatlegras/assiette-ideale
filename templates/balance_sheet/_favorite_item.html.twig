<div>
    {# Vérifie si un élément existe pour l’affichage #}
    {% if item is not null %}
        {# Conteneur horizontal pour l’image et le lien du plat/aliment #}
        <div class="flex text-sm gap-2 items-center mb-2">

            {# Affichage de l’image si elle existe, sinon placeholder #}
            {% if item.picture is not null and item.picturePath is not null %}
                <img alt="Photo plat" class="rounded-lg w-8 mt-1" src="{{ item.picturePath|imagine_filter('squared_thumbnail_small') }}">
            {% else %}
                <img src="https://via.placeholder.com/50" alt="Photo plat" class="rounded-lg w-8 mt-1">
            {% endif %}

            {# Lien vers la page du plat ou de l’aliment selon le type d’objet #}
            <a 
                {% if instanceOf(item, 'App\\Entity\\Dish') %} 
                    href="{{ path('app_dish_show', { id: item.id, slug: item.slug }) }}" 
                {% else %} 
                    href="{{ path('app_food_show', { slug: item.slug }) }}" 
                {% endif %} 
                class="text-sky-600 hover:text-sky-700 font-semi-bold transition duration-300 text-sm tracking-tight"
            >
                {{ item.name }}
            </a>

        </div>

    {% else %}
        {# Message affiché si aucun élément n’est trouvé #}
        <span class="text-sm text-neutral-500">
            Aucun {{ type == 'food' ? 'aliments' : 'plats' }} trouvés pour cette période
        </span>
    {% endif %}
</div>