<div class="flex flex-col lg:flex-row gap-6 bg-white shadow-soft rounded-2xl p-4 text-sm">

    {# Colonne gauche : informations principales du plat #}
    <div class="flex flex-col gap-3 lg:w-1/2">

        {# Champ caché pour l'ID du plat si défini #}
        <input type="hidden" name="dish[dish_id]" value="{{ dish is defined ? dish.id : null }}" />

        {# Nom du plat #}
        <div>
            {{ form_label(dishForm.name, 'Nom du plat', {'label_attr' : {'class' : 'form-label text-lg'}}) }}
            {{ form_errors(dishForm.name) }}
            {{ form_widget(dishForm.name) }}
        </div>

        {# Type du plat #}
        <div class="mt-2">
            {{ form_label(dishForm.type, 'Type du plat', {'label_attr' : {'class' : 'form-label text-lg'}}) }}
            {{ form_errors(dishForm.type) }}
            {{ form_widget(dishForm.type) }}
        </div>

        {# Niveau de difficulté #}
        <div class="mt-2">
            {{ form_label(dishForm.level, null, {'label_attr' : {'class' : 'form-label text-lg'}}) }}
            {{ form_errors(dishForm.level) }}
            {{ form_widget(dishForm.level) }}
        </div>

        {# Bloc pour nombre de personnes et temps de préparation/cuisson #}
        <div class="form-group flex flex-col md:flex-row gap-4 mt-2">
            <div class="col-span-4 flex flex-col">
                {# Nombre de personnes #}
                {{ form_label(dishForm.lengthPersonForRecipe, 'Nombre de personnes', {'label_attr' : {'class' : 'form-label'}}) }}
                {{ form_errors(dishForm.lengthPersonForRecipe) }}
                <div>
                {{ form_widget(dishForm.lengthPersonForRecipe) }}
                </div>
            </div>
            <div class="col-span-4 flex flex-col">
                {# Temps de préparation #}
                {{ form_label(dishForm.preparationTime, 'Temps de préparation', {'label_attr': {'class' : 'form-label'}}) }}
                {{ form_errors(dishForm.preparationTime) }}
                <div class="flex flex-row gap-2">
                    {{ form_widget(dishForm.preparationTime) }}
                    {{ form_widget(dishForm.preparationTimeUnitTime) }}
                </div>
            </div>
            <div class="col-span-4 flex flex-col">
                {# Temps de cuisson #}
                {{ form_label(dishForm.cookingTime, 'Temps de cuisson', {'label_attr': {'class' : 'form-label'}}) }}
                {{ form_errors(dishForm.cookingTime) }}
                <div class="flex flex-row gap-2">
                    {{ form_widget(dishForm.cookingTime) }}
                    {{ form_widget(dishForm.cookingTimeUnitTime) }}
                </div>
            </div>
        </div>

        {# Section photo du plat #}
        <div>
            <label class="text-lg">Photo</label>

            {# Si une photo existe, affichage de la miniature et bouton supprimer #}
            {% if dish.picture is defined and dish.picturePath is not null %}
                <div class="w-24 h-24 relative image-fit cursor-pointer zoom-in">
                    <a href="{{ uploaded_asset(dish.picturePath) }}">
                        <img class="rounded-md" alt="Image plat {{ dish.name ?? '' }}" src="{{ dish.picturePath|imagine_filter('squared_thumbnail_small') }}">
                        <a href="#" title="Supprimer l'image?" class="remove-pic foo tooltip w-5 h-5 flex items-center justify-center absolute rounded-full text-white bg-red-500 right-0 top-0 -mr-2 -mt-2">
                            <svg class="w-2 h-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="#fff" viewBox="0 0 14 14">
                                <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"></path>
                            </svg>
                        </a>
                    </a>
                </div>
            {% endif %}

            {# Gestion des erreurs liées à la photo #}
            {% if app.session.has('recipe_error_pic') %}
                <span class="text-red-700">
                    {{ render(controller('App\\Controller\\DishController::showErrorPicture')) }}
                </span>
            {% endif %}

            {{ form_label(dishForm.pictureFile) }}
            {{ form_errors(dishForm.pictureFile) }}
            {{ form_widget(dishForm.pictureFile, {'attr': {'class': 'bg-white'}}) }}
        </div>

        {# Section étapes de préparation #}
        <div class="mt-2">
            {{ form_label(dishForm.stepRecipes, 'Etapes de préparation', {'label_attr': {'class': 'text-lg'}}) }}
            {{ form_errors(dishForm.stepRecipes) }}
            
            <div>
                {# Liste des étapes avec prototype pour ajout dynamique #}
                <ul class="step-recipes"
                    data-index="{{ dishForm.stepRecipes|length > 0 ? dishForm.stepRecipes|last.vars.name + 1 : 0 }}"
                    data-prototype="{{ form_widget(dishForm.stepRecipes.vars.prototype)|e('html_attr') }}"
                >
                    {% for stepRecipe in dishForm.stepRecipes %}
                        <li>
                            {{ form_row(stepRecipe.description) }}
                        </li>
                    {% endfor %}
                </ul>

                {# Bouton pour ajouter une étape #}
                <button type="button" class="add_item_link mt-3 flex flex-row items-center gap-2 bg-light-blue text-white font-bold py-1 px-4 rounded-lg" data-collection-holder-class="step-recipes">
                    <svg viewBox="0 0 24 24"  class="w-5 h-5" fill="#ffffff"><path ...></path></svg>
                    <span>Ajouter une étape</span>
                </button>

                {# Script JS pour ajouter/supprimer dynamiquement les étapes #}
                <script>
                    const addFormToCollection = (e) => { ... }
                    const addTagFormDeleteLink = (item) => { ... }

                    document.querySelectorAll('ul.step-recipes li').forEach((stepRecipe) => {
                        addTagFormDeleteLink(stepRecipe)
                    });

                    document.querySelectorAll('.add_item_link').forEach(btn => {
                        btn.addEventListener("click", addFormToCollection)
                    });
                </script>
            </div>
        </div>

        {{ form_widget(dishForm._token) }}
        
    </div>

    {# Colonne droite : valeurs nutritionnelles et ingrédients #}
    <div class="flex flex-col lg:w-1/2 items-start">

        {# Modal pour ajouter des valeurs nutritionnelles #}
        {{ include('dish/_modal_add_nutrional_values.html.twig') }}

        {# Affichage des valeurs nutritionnelles #}
        <div class="flex w-full">
            <div class="flex w-1/3 gap-2">
                <span>Proteines</span>
                <span id="protein-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Lipides</span>
                <span id="lipid-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Acides gras saturés</span>
                <span id="saturated-fatty-acid-value"></span>
            </div>
        </div>

        <div class="flex w-full">
            <div class="flex w-1/3 gap-2">
                <span>Glucides</span>
                <span id="carbohydrate-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Sucres</span>
                <span id="sugar-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Sel</span>
                <span id="salt-value"></span>
            </div>
        </div>

        <div class="flex w-full">
            <div class="flex w-1/3 gap-2">
                <span>Fibres</span>
                <span id="fiber-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Energie</span>
                <span id="energy-value"></span>
            </div>
            <div class="flex w-1/3 gap-2">
                <span>Nutriscore</span>
                <span id="nutriscore-value"></span>
            </div>
        </div>

        {# Section ingrédients avec autocomplete Stimulus #}
        <label class="mt-2 text-lg">Ingrédients</label>
    
        <div 
            class="w-full"
            {{ stimulus_controller(
                    'autocomplete', { 
                        url: path('app_dish_food_list_preview', {idDish: idDish}),
                        skipHiddenProperty: true 
                    }
                ) 
            | 
                stimulus_controller('autocomplete-transition')
            }}
            data-action="toggle->autocomplete-transition#toggle"
        >
            {# Affichage des erreurs si quantité incorrecte #}
            {% if app.session.has('food_error_quantity') %}
                <span class="text-red-700">
                    {{ render(controller('App\\Controller\\DishController::showErrorFoodQuantity')) }}
                </span>
            {% endif %}

            <input
                name="q"
                placeholder="Miel, côte de porc..."
                type="search"
                class="form-control w-full rounded-lg" style="height: 50px"
                data-autocomplete-target="input"
            >
            <div 
                data-autocomplete-target="results"
                data-autocomplete-transition-target="results"
            ></div>
        </div>

        {# Liste des aliments ajoutés avec leurs quantités #}
        <div class="my-4">
            {{ form_errors(dishForm.dishFoodList) }}
            {% for field in dishForm %}
                {% if field.vars.food_group is defined %}
                    {{ form_widget(field, {'attr': {'data-food-group-id': field.vars.food_group.id}}) }}             
                {% endif %}
            {% endfor %}
        </div>          

        {# Modal pour ajouter/modifier la quantité d'un aliment #}
        {{ include('dish/_modal_add_quantity_food.html.twig') }}

        {# Fin du formulaire Symfony #}
        {{ form_end(dishForm, {render_rest: false}) }}
            
        {# Liste des aliments déjà ajoutés #}
        {{ include("dish/_list_foods.html.twig") }}
    
    </div>

</div>