{% extends "base.html.twig" %}

{# =========================================================
   Page profil utilisateur
   Affiche les informations personnelles, les régimes
   alimentaires et les aliments interdits
========================================================= #}

{% block title %}{{ parent() }} - Mon profil{% endblock %}

{% block body %}

	<div class="py-12 relative">

		{# Message éventuel d'ajustement énergétique (calcul calories etc.) #}
		{{ render(path('app_energy_adjustment_message')) }}

        {# Header de page avec le titre #}
        {{ include('navigation/_header_page.html.twig', {title: 'Mes informations'}) }}

		{# Container principal du profil #}
		<div {{ stimulus_controller('alert-imc-weight-modal') }} class="bg-white shadow-balanced rounded-2xl p-6">

			{# =========================================================
			   SECTION : Informations principales utilisateur
			   Photo + username + email + accès modification mot de passe
			========================================================= #}

			<div class="flex flex-col lg:flex-row">

				<div class="flex flex-col lg:flex-row flex-1 p-5 relative items-start">

					{# Avatar utilisateur #}
					<div class="w-20 h-20 flex-none lg:w-32 lg:h-32 image-fit relative">

						{# Si l'utilisateur possède une photo #}
						{% if app.user.picture is not null %}

							<div class="rounded-full flex items-center justify-center text-6xl h-full border border-slate-300">
								<img class="rounded-full"
								     alt="Photo de l'utilisateur {{ app.user.username }}"
								     src="{{ app.user.picturePath|imagine_filter('squared_thumbnail_medium') }}">
							</div>

						{% else %}

							{# Avatar par défaut si aucune photo #}
							<div class="rounded-full flex items-center justify-center text-6xl h-full border border-slate-300">
								<svg fill="none" class="w-12 h-12 text-slate-300" stroke="currentColor" stroke-width="1.5" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round"
									      d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169"/>
								</svg>
							</div>

						{% endif %}

					</div>

					{# Nom utilisateur + email #}
					<div class="flex flex-col ml-0 lg:ml-5 mt-2">

						<div class="flex flex-row items-center w-full">

							{# Username #}
							<div class="sm:whitespace-normal font-semibold text-2xl text-gray-700">
								{{ app.user.username }}
							</div>

							{# Bouton édition paramètres #}
							<div class="flex items-center">
								{{ include('profile/partials/_icon_edit.html.twig',
									{ element: constant('App\\Service\\ProfileHandler::PARAMETERS') }) }}
							</div>

						</div>

						{# Email utilisateur #}
						<div class="flex items-center font-semibold text-sky-600 text-sm md:text-base -ml-1">
							{{ app.user.email }}
						</div>

					</div>

				</div>

				{# Lien modification mot de passe #}
				<div class="ml-0 px-5 md:ml-auto flex flex-row items-center text-sm gap-2">

					<a href="{{ path('app_profile_password_edit') }}"
					   class="text-sky-600 hover:text-sky-700 duration-300 transition">

						Modifier le mot de passe

					</a>

				</div>

			</div>

			{# =========================================================
			   SECTION : Informations personnelles
			   genre, âge, taille, poids
			========================================================= #}

			<div class="flex flex-col lg:flex-row">

				<div class="flex flex-col flex-1">

					{# Informations biométriques #}
					<div class="relative flex-1 px-5 pt-5">

						<div class="flex flex-col justify-center items-center lg:items-start">

							{# Genre #}
							<div class="flex items-center w-full">
								<label class="flex items-center w-24 justify-between">
									<span>{% trans from 'profile' %}profile.gender.label1{% endtrans %}</span>
								</label>

								<span>
									{{ app.user.gender.name|trans({}, 'profile')
										|default("Vous n'avez pas renseigné votre genre") }}
								</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{element: constant('App\\Service\\ProfileHandler::GENDER')}) }}

							</div>

							{# Tranche d'âge #}
							<div class="flex items-center mt-2 w-full">

								<label class="flex items-center w-24 justify-between">
									<span>{% trans from 'profile' %}profile.age.label1{% endtrans %}</span>
								</label>

								<span>
									{{ app.user.ageRange.description|trans({}, 'profile')
										|default("Vous n'avez pas renseigné votre tranche d'âge") }}
								</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{element: constant('App\\Service\\ProfileHandler::AGE_RANGE')}) }}

							</div>

							{# Taille #}
							<div class="flex items-center mt-2 w-full">

								<label class="flex items-center w-24 justify-between">
									<span>{% trans from 'profile' %}profile.height.label1{% endtrans %}</span>
								</label>

								<span>
									{{ 'profile.height.value'
										|trans({'value': app.user.height}, domain='profile')
										|default("Vous n'avez pas renseigné votre taille") }}
								</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{element: constant('App\\Service\\ProfileHandler::HEIGHT')}) }}

							</div>

							{# Poids #}
							<div class="flex items-center mt-2 w-full">

								<label class="flex items-center w-24 justify-between">
									<span>{% trans from 'profile' %}profile.weight.label1{% endtrans %}</span>
								</label>

								{{ 'profile.weight.value'
									|trans({'value': app.user.weight}, domain='profile')
									|default("Vous n'avez pas renseigné votre poids") }}

								{{ include('profile/partials/_icon_edit.html.twig',
									{element: constant('App\\Service\\ProfileHandler::WEIGHT')}) }}

							</div>

						</div>

					</div>

					{# =========================================================
					   SECTION : Activité physique
					========================================================= #}

					<div class="relative flex-1 pt-5 px-5">

						<div class="flex items-center gap-2 mb-2">
							<label class="font-bold uppercase">
								{% trans from 'profile' %}profile.physical_activities.label{% endtrans %}
							</label>
						</div>

						<div class="flex flex-1 flex-col items-center justify-center">

							{# Horaires d'activité #}
							<div class="flex items-center w-full">
								<span>{{ app.user.hour|trans({}, 'profile')
									|default("Vous n'avez pas indiqué vos horaires") }}</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{ element: constant('App\\Service\\ProfileHandler::HOURS') }) }}
							</div>

							{# Type de travail #}
							<div class="flex items-center justify-start mt-2 w-full">
								<span>{{ app.user.workingType.description|trans({}, 'profile')
									|default("Vous n'avez pas saisi votre type de métier") }}</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{ element: constant('App\\Service\\ProfileHandler::WORK') }) }}
							</div>

							{# Temps de sport #}
							<div class="flex items-center justify-start mt-2 w-full">
								<span>{{ app.user.sportingTime.description|trans({}, 'profile')
									|default("Vous n'avez pas saisi votre type de métier") }}</span>

								{{ include('profile/partials/_icon_edit.html.twig',
									{ element: constant('App\\Service\\ProfileHandler::SPORT') }) }}
							</div>

						</div>

					</div>

				</div>

				{# =========================================================
				   SECTION : Régimes alimentaires + aliments interdits
				========================================================= #}

				<div class="flex flex-col flex-1 p-5">

					{# Liste des régimes #}
					<div class="flex items-center gap-3 uppercase font-bold mb-2">
						<span>{% trans from 'profile' %}profile.diets.label1{% endtrans %}</span>

						{{ include('profile/partials/_icon_edit.html.twig',
							{element: constant('App\\Service\\ProfileHandler::DIETS')}) }}

						{# Lien vers page explicative des régimes #}
						<a href="{{ path('app_diets_index') }}" class="ml-auto">
							<svg class="w-6 h-6 ml-auto" fill="currentColor"></svg>
						</a>
					</div>

					{# Affichage des régimes sélectionnés #}
					<div class="flex flex-col justify-center items-center lg:items-start mt-2 relative">

						{% if app.user.diets is not empty %}

							<ul class="flex flex-wrap justify-start gap-2 w-full">

								{% for diet in app.user.diets %}

									<li>
										<span class="inline-flex items-center justify-center px-2 py-3 font-bold leading-none text-white bg-green-700 rounded">
											{{ diet.name }}
										</span>
									</li>

								{% endfor %}

							</ul>

						{% else %}

							{# Aucun régime sélectionné #}
							{% trans from 'profile' %}profile.diets.none{% endtrans %}

						{% endif %}

					</div>

					{# Toggle affichage aliments interdits par les régimes #}
					<div class="toggle-container"
						{{ stimulus_controller('toggle-visibility-forbidden-items',
							{ url: path('app_diets_toggle_visibility_diet_items') }) }}
					>

						<label class="switch">

							<input type="checkbox"
								{% if app.user.showDietFoods %}checked{% endif %}
								data-action="change->toggle-visibility-forbidden-items#toggle">

							<span class="slider"></span>

						</label>

						<span class="toggle-label">
							Afficher les aliments interdits par mes régimes dans mes choix
						</span>

					</div>

					{# =========================================================
					   SECTION : Aliments interdits
					========================================================= #}

					<div class="flex items-center gap-3 uppercase font-bold mt-6 mb-2">
						<span>{% trans from 'profile' %}profile.forbidden_foods.label1{% endtrans %}</span>

						{{ include('profile/partials/_icon_edit.html.twig',
							{element: constant('App\\Service\\ProfileHandler::FORBIDDEN_FOODS')}) }}
					</div>

					{# Liste des aliments interdits #}
					<div class="flex flex-col justify-center items-center lg:items-start mt-2 relative">

						{% if app.user.forbiddenFoods is not empty %}

							<ul class="flex flex-wrap justify-start gap-2 w-full">

								{% for forbiddenFood in app.user.forbiddenFoods %}

									<li>
										<span class="inline-flex items-center justify-center px-2 py-3 font-bold leading-none text-white bg-dark-blue rounded">
											{{ forbiddenFood.name }}
										</span>
									</li>

								{% endfor %}

							</ul>

						{% else %}

							{# Aucun aliment interdit défini #}
							{% trans from 'profile' %}profile.forbidden_foods.none{% endtrans %}

						{% endif %}

					</div>

					{# Toggle affichage aliments non consommés #}
					<div class="toggle-container"
						{{ stimulus_controller('toggle-visibility-forbidden-items',
							{ url: path('app_diets_toggle_visibility_forbidden_items') }) }}
					>

						<label class="switch">

							<input type="checkbox"
								{% if app.user.showForbiddenFoods %}checked{% endif %}
								data-action="change->toggle-visibility-forbidden-items#toggle">

							<span class="slider"></span>

						</label>

						<span class="toggle-label">
							Afficher les aliments non consommés dans mes choix
						</span>

					</div>

				</div>

			</div>

		</div>

	</div>

{% endblock %}