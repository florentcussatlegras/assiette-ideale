{% extends "security/_layout.html.twig" %}

{% block content %}

    <div class="flex flex-col gap-2">

        {# Titre principal de la page #}
        <h1 class="text-4xl font-bold text-white text-center">
            Réinitialiser votre mot de passe
        </h1>

        {# Description ou instructions pour l'utilisateur #}
        <p class="mt-2 text-white">
            Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.
        </p>

        {# Début du formulaire Symfony #}
        {{ form_start(requestForm, {'attr': {'class': 'security'}}) }}
            
            {# Champ email avec placeholder et style Tailwind #}
            {{ form_widget(requestForm.email, {'attr' : {'class' : 'block w-full bg-white rounded-lg border-none text-gray-900', 'placeholder': 'Votre adresse e-mail'}}) }}
            
            {# Affichage des erreurs spécifiques au champ email #}
            {{ form_errors(requestForm.email) }}

            {# Bouton de soumission et liens vers connexion / inscription #}
            <div class="text-center mt-7 text-sm">
                {# Bouton de validation du formulaire #}
                <button class="bg-sky-700 hover:bg-sky-800 text-white w-full font-bold py-3 text-base cursor-pointer rounded-lg transition duration-300">
                    Valider
                </button>

                {# Lien pour revenir au formulaire de connexion #}
                <div class="mt-7 text-white">
                    Déja inscrit? <br>
                    <a href="{{ path('app_login') }}" class="text-white hover:text-sky-900 duration-300 transition font-semibold">
                        Identifiez-vous
                    </a>
                </div>

                {# Lien pour accéder à l'inscription #}
                <div class="mt-7 text-white">
                    Pas encore de compte? <br>
                    <a href="{{ path('app_register') }}" class="text-white hover:text-sky-800 duration-300 transition font-semibold">
                        Inscrivez-vous en moins de 5 min!
                    </a>
                </div>
            </div>

        {# Fin du formulaire Symfony #}
        {{ form_end(requestForm) }}

    </div>

{% endblock %}