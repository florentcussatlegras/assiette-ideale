<div class="card card-wrapper shadow-balanced rounded-xl">

    {# Colonne gauche : image de l’aliment et info basique #}
    <div class="card-col-left">

        {# Lien vers la fiche détaillée de l’aliment #}
        <a href="{{ path('app_food_show', {'slug': food.slug}) }}" class="flex items-center justify-center h-full">

            {# Affichage de l’image si elle existe, sinon placeholder #}
            {% if food.picture is not null and food.picturePath is defined %}
                <img class="rounded-md" alt="Photo de l'aliment {{ food.name }}" src="{{ food.picturePath|imagine_filter('squared_thumbnail_medium') }}" width="250px">
            {% else %}
                <img class="rounded-md" alt="Photo de l'aliment {{ food.name }}" src="https://via.placeholder.com/500">
            {% endif %}
            
        </a>

        {# Nom de l’aliment et info gluten/lactose #}
        <div class="flex flex-col gap-2">
            <a href="{{ path('app_food_show', {'slug': food.slug}) }}" class="block text-base truncate font-normal">
                {{ food.name }}
            </a>

            {# Inclusion des badges gluten/lactose #}
            {{ include('partials/_have_gluten_lactose.html.twig', {item: food}) }}
        </div>

    </div>

    {# Colonne droite : informations nutritionnelles et quantité (si dans session recette) #}
    <div class="card-col-right">

        {# Bloc des informations nutritionnelles de l’aliment #}
        <div>{{ include('food/_nutritional_informations.html.twig') }}</div> 

        {# Si on ajoute l’aliment à une recette, afficher le sélecteur de quantité et d’unité #}
        {% if app.session.has('recipe_dish') %}

            <div class="select-quantity">

                {# Champ de saisie de la quantité #}
                <input name="foods[{{ food.id }}][quantity]" type="number" step="0.01" class="form-control col-span-6 w-1/2" placeholder="Quantité" aria-label="default input inline 1"> 
            
                {# Sélecteur d’unité #}
                <select name="foods[{{ food.id }}][unit_measure]" class="form-select sm:mr-2 col-span-6" aria-label="Default select example">
                
                    {# Boucle sur les unités disponibles pour l’aliment #}
                    {% for unitMeasure in food.unitMeasures %}

                        {# Afficher seulement les unités valides : avec gramRatio ou pouvant être une part #}
                        {% if (unitMeasure.gramRatio is not null) or (food.canBeAPart == true and unitMeasure.gramRatio is null) %}
                
                            <option value="{{ unitMeasure.alias }}" 
                                {# Sélectionner l’unité si elle correspond à ce qui est déjà dans la session recette #}
                                {% if food.foodGroup.alias in app.session.get('recipe_foods')|keys 
                                and food.id in app.session.get('recipe_foods')[food.foodGroup.alias]|keys
                                and app.session.get('recipe_foods')[food.foodGroup.alias][food.id]['unit_measure'] == unitMeasure.alias %} 
                                    selected="selected"
                                {% endif %}>

                                {{ unitMeasure.alias }}
                                
                            </option>

                        {% endif %}

                    {% endfor %}
                
                </select>
            
            </div>

        {% endif %}
    
    </div>

</div>