{# Conteneur principal des pictogrammes des groupes d'aliments #}
<div class="plist flex gap-6 mx-12 pb-2 justify-end">

    {# Boucle sur chaque groupe d'aliment parent #}
    {% for foodGroupParent in foodGroupParents %}

        {# Lien cliquable autour du pictogramme #}
        <a href="#" class="fgp" title="{{ foodGroupParent.name }}">

            {# Pictogramme avec couleur de fond dégradée #}
            <div class="picto w-12 h-12 flex items-center justify-center" style="background-color:{{ foodGroupParent.degradedColor }}">
                
                {# Inclusion du SVG spécifique au groupe avec sa couleur principale #}
                {{ include('meals/pictos/foodgroupparent/' ~ foodGroupParent.alias ~ '.xml.twig', {'color' : foodGroupParent.color }) }}
            </div>
        
        </a>

    {% endfor %}
    
</div>