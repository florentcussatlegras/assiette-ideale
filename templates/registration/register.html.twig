{% extends "security/_layout.html.twig" %}

{# Utilisation du même template pour le thème du formulaire #}
{% form_theme registerForm _self %}

{# Titre de la page #}
{% block title %}S'inscrire{% endblock %}

{% block content %}

    {# Début du formulaire avec classes CSS et désactivation de la validation HTML #}
    {{ form_start(registerForm, {'attr' : {'novalidate' : 'novalidate', 'class': 'security'}}) }}

        {# Affiche les erreurs globales du formulaire #}
        {{ form_errors(registerForm) }}

        {# En-tête du formulaire avec titre et sous-titre #}
        <div class="flex flex-col items-center">
            <h1 class="text-4xl font-bold text-white">
                Inscription
            </h1>
            <div class="mt-2 text-xl text-white text-center">Encore quelques clics pour vous connecter à votre compte !</div>
        </div>
        
        {# Champs principaux du formulaire : email, username, mot de passe #}
        <div class="mt-8 flex flex-col gap-3 text-sm">

            {# Champ email #}
            <div>
                {# Erreurs liées au champ email #}
                <span class="text-red-500">{{ form_errors(registerForm.email) }}</span>
                {# Widget du champ email avec placeholder et style Tailwind #}
                {{ form_widget(registerForm.email, {'attr': {'placeholder': 'Adresse e-mail', 'class': 'block w-full bg-white rounded-lg border-none text-gray-900'}}) }}
            </div>

            {# Champ username #}
            <div>
                {# Erreurs liées au champ username #}
                <span class="text-red-500">{{ form_errors(registerForm.username) }}</span>
                {# Widget du champ username #}
                {{ form_widget(registerForm.username, {'attr': {'placeholder': "Nom d'utilisateur", 'class': 'block w-full bg-white rounded-lg border-none text-gray-900'}}) }}
            </div>

            {# Champ mot de passe #}
            <div 
                {# Commentaire pour le controller Stimulus (actuellement désactivé) #}
                {# {{ stimulus_controller('password-validation') }} #}
            >
                {# Erreurs liées au champ mot de passe #}
                <span class="text-red-500">{{ form_errors(registerForm.plainPassword) }}</span>
       
                {# Champ mot de passe avec bouton de visibilité #}
                <div data-controller="password-visibility" class="relative flex items-center">
                    {{ form_widget(registerForm.plainPassword, {'attr': {'id': 'psw', 'placeholder': "Mot de passe", 'class': 'block w-full bg-white rounded-lg border-none text-gray-900'}}) }}
                    {{ include('partials/_button_visibility_pwd.html.twig') }}
                </div>

                {# Ancien message de validation du mot de passe commenté #}
                {# <div id="message" class="flex flex-col gap-1">
                    <label class="text-sm">Le mot de passe doit contenir:</label>
                    <div id="letter" class="invalid-password text-xs pl-6 flex items-center">Une lettre minuscule</div>
                    <div id="capital" class="invalid-password text-xs pl-6 flex items-center">Une lettre majuscule</div>
                    <div id="number" class="invalid-password text-xs pl-6 flex items-center">Un nombre</div>
                    <div id="length" class="invalid-password text-xs pl-6 flex items-center">8 caractères minimums</div>
                </div> #}

            </div>

        </div>

        {# Champ de case à cocher pour accepter les termes et conditions #}
        <div class="flex flex-col mt-6 text-sm">
            {# Erreurs liées au champ terms #}
            <span class="text-red-500">{{ form_errors(registerForm.terms) }}</span>
            <div class="flex flex-row gap-1">
                <div>
                    {{ form_widget(registerForm.terms) }}
                </div>
                <div class="mt-1">
                    {# Label pour la case à cocher avec style #}
                    {{ form_label(registerForm.terms, null, {'label_attr': {'class': 'text-white font-light'}}) }}
                </div>
            </div>
        </div>

        {# Bouton de soumission et lien vers la page de connexion #}
        <div class="button-group text-center mt-4">
            <button type="submit" class="bg-sky-800 hover:bg-sky-700 text-white w-full font-bold py-3 text-base cursor-pointer rounded-lg transition duration-300">Valider</button>
            <div class="mt-5 text-sm text-white">Déja inscrit? <br><a href="{{ path('app_login') }}" class="text-white hover:text-sky-900 transition duration-300 text-sm font-semibold">Identifiez-vous</a></div>
        </div>

        {# Mention légale sur les termes et conditions avec lien #}
        <div class="mt-7 text-white text-center text-sm">
			En vous inscrivant, vous acceptez nos
			<br>
			<a class="text-white hover:text-sky-900 transition duration-300 font-semibold" href="{{ path('app_terms') }}">Termes et Conditions</a>
		</div>

    {# Fin du formulaire #}
    {{ form_end(registerForm) }}

{% endblock %}