{% extends "base.html.twig" %}

{% block title %}{{ parent() }} - Les plats{% endblock %}

{% block body %}

    <div class="py-12">

        {# Définition du titre de la page pour le header #}
        {% set title = dish.name %}

        {# Inclusion du header de navigation avec le titre #}
        {{ include('navigation/_header_page.html.twig') }}

        {# Conteneur principal du plat avec Stimulus controller pour les favoris #}
        <div 
            {{ stimulus_controller('favorite-dishes', {
                'url': path('app_favorite_dishes_list', {'ajax': 1}),
                'urlAdd': path('app_favorite_dishes_add'),
                'urlRemove': path('app_favorite_dishes_remove')
            }) }}
            class="bg-white px-10 flex flex-col lg:flex-row pt-20 md:pt-8 pb-12 w-full shadow-balanced rounded-xl relative"
        >

            {# Bloc des boutons favoris et partage #}
            <div class="absolute left-6 md:left-auto md:right-6 top-6">

                <div class="flex flex-row gap-4 items-center">

                    {# Bouton favoris visible uniquement si l'utilisateur est connecté #}
                    {% if is_granted('IS_AUTHENTICATED') %}
                        <button 
                            data-action="favorite-dishes#toggle"
                            data-dish-id="{{ dish.id }}"
                            class="btn-heart cursor-pointer p-3 rounded-full border"
                        >
                            {# Coeur vide si le plat est déjà dans les favoris #}
                            <span class="heart {{ dish.id in favoriteDishesId ? 'hidden' }}">
                                <svg ...></svg>
                            </span>
                            {# Coeur rempli si le plat n'est pas dans les favoris #}
                            <span class="heart-fill {{ dish.id not in favoriteDishesId ? 'hidden' }}">
                                <svg ...></svg>
                            </span>
                        </button>
                    {% endif %}

                    {# Bloc pour partager la recette avec Stimulus controller #}
                    <div {{ stimulus_controller('share-recipe', {
                        url: path('app_dish_show', { id: dish.id, slug: dish.slug })
                    }) }}>
                        
                        <button
                            data-action="click->share-recipe#open"
                            data-share-recipe-dish-id-value="{{ dish.id }}"
                            class="cursor-pointer p-3 rounded-full border"
                        >
                            <svg ...></svg>
                        </button>

                        {# Overlay + modal de partage #}
                        {{ include('dish/partials/_modal_share_recipe.html.twig') }}

                    </div>

                </div>

            </div>

            {# Colonne principale gauche et droite du plat #}
            <div class="flex flex-col w-full lg:w-1/2">

                <div class="flex flex-col md:flex-row lg:flex-col 2xl:flex-row flex-1">

                    {# Bloc image et niveau du plat #}
                    <div class="flex flex-col">

                        <div class="flex flex-row justify-between mb-2">

                            {# Niveau de difficulté du plat #}
                            <span class="flex items-center text-lg px-4 font-bold bg-slate-200 uppercase rounded">
                                {{ dish.level|trans({}, 'recipe') }}
                            </span>

                            {# Actions admin : modifier ou supprimer le plat #}
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="flex items-center ml-auto gap-2">

                                    <a href="{{ path('app_dish_food_session_clear', { id : dish.id }) }}">
                                        {{ include("partials/svg/edit.html.twig") }}
                                    </a>

                                    <a href="{{ path('app_dish_remove', { id : dish.id }) }}">
                                        {{ include("partials/svg/remove.html.twig") }}
                                    </a>

                                </div>
                            {% endif %}
                        </div>

                        {# Image du plat #}
                        <div>
                            {% if dish.picture is empty %}
                                <img class="w-full h-64 image-fit" src="https://via.placeholder.com/800">
                            {% else %}
                                <img alt="Image plat" class="image-fit" src="{{ dish.picturePath|imagine_filter('squared_thumbnail_medium') }}">
                            {% endif %}
                        </div>
                    </div>

                    {# Bloc informations et ingrédients #}
                    <div class="flex flex-col flex-1 py-2 px-6">
                        
                        <h1 class="text-xl font-bold mt-5">Ingrédients</h1>
                        <label class="text-sm">{{ 'recipe.person'|trans({'length' : dish.lengthPersonForRecipe}, 'recipe') }}</label>
                
                        <ul class="font-normal mt-0 text-base">
                            {# Liste des ingrédients avec couleur par groupe alimentaire #}
                            {% for dishFood in dish.dishFoods %}
                                <li class="flex items-center gap-2">
                                    <span class="w-2 h-2 rounded-sm" style="border: 1px solid {{ dishFood.food.foodGroup.parent.color }}; background-color: {{ dishFood.food.foodGroup.parent.color }}"></span>
                                    {{ dishFood.quantityReal }} {{ dishFood.unitMeasure.alias }} de <a href="{{ path('app_food_show', {slug: dishFood.food.slug}) }}" class="text-sky-600">{{ dishFood.food.name }}</a>
                                </li>
                            {% endfor %}
                            {# Liste des épices #}
                            {% for spice in dish.spices %}
                                <li>{{ spice.name }}</li> 
                            {% endfor %}
                        </ul>
                        
                        {# Informations sur gluten et lactose #}
                        <div class="flex gap-2 mt-2 text-sm">
                            <span class="font-bold bg-yellow-100 text-yellow-800 px-4 py-1 rounded uppercase">
                            {% if dish.haveGluten %}
                                Avec gluten
                            {% else %}
                                Sans gluten
                            {% endif %}
                            </span>
                            <span class="font-bold bg-slate-100 text-sky-800 px-4 py-1 rounded uppercase">
                            {% if dish.haveLactose %}
                                Avec lactose
                            {% else %}
                                Sans lactose
                            {% endif %}
                            </span>
                        </div>

                        {# Affichage du Nutri-Score #}
                        <img src='{{ asset("svg/nutriscore/Nutri-score-#{dish.nutritionalTable.nutriscore}.svg") }}' class="my-4" width="120px" />

                    </div>     

                </div>

                {# Recommandations de portions #}
                <div class="py-2 px-6">
                    {{ render(path('app_dish_quantities_recommended_by_portion', {id: dish.id})) }}
                </div>

            </div>

            {# Section préparation si étapes existantes #}
            {% if dish.stepRecipes|length > 0 %}

                <div class="flex flex-col pt-2  px-6 w-full lg:w-1/2 text-base">
        
                    <h1 class="text-xl font-bold mt-5 mb-2">Préparation</h1>

                    {# Temps de préparation #}
                    {% if dish.preparationTimeUnitTime is not null %}           
                        <div class="flex gap-3 items-center">
                            <label>{{ 'recipe.time.label.preparation'|trans({}, 'recipe') }} : </label>
                            <span class="font-normal">
                                {{ 'recipe.time.value'|trans({'duration' : dish.preparationTime, 'unit_time' : dish.preparationTimeUnitTime.alias}, 'recipe') }}
                            </span>
                        </div>
                    {% endif %}

                    {# Temps de cuisson #}
                    {% if dish.cookingTimeUnitTime is not null %} 
                        <div class="flex gap-2 items-center mb-2">
                            <label>{{ 'recipe.time.label.cooking'|trans({}, 'recipe') }} : </label>
                            <span class="font-normal">
                                {{ 'recipe.time.value'|trans({'duration' : dish.cookingTime, 'unit_time' : dish.cookingTimeUnitTime.alias}, 'recipe') }}
                            </span>
                        </div>
                    {% endif %}

                    {# Liste des étapes de préparation #}
                    {% for stepRecipe in dish.stepRecipes %}
                        <div class="flex items-start gap-2">
                            <span class="font-bold text-slate-300">{{ stepRecipe.rankStep }}</span>
                            <span>{{ stepRecipe.description|raw }}</span>
                        </div>
                    {% endfor %}

                    {# Bloc valeurs nutritionnelles commenté pour l'instant #}
                    {# <div class="mt-4">
                        {{ include('dish/_nutritional_values.html.twig', { ignore_missing: true }) }}
                    </div> #}

                </div>

            {% endif %}

        </div>

    </div>

{% endblock %}