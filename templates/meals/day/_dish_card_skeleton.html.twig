<div class="flex flex-col w-full py-8 px-4 relative rounded-2xl shadow-soft bg-white animate-pulse">
    
    {# Petit badge d’alerte en haut à gauche si ce n’est pas un modèle #}
    {% if app.session.get('_meal_day_date') != 'model' %}
        <div class="alerts absolute -top-2 -left-2 bg-gray-200 w-12 h-12 rounded-full">
            {# Cercle gris simulant l’icône d’alerte #}
        </div>
    {% endif %}

    {# Ligne principale : image + contenu #}
    <div class="flex flex-row items-center md:flex-row md:max-w-xl p-2 bg-white">

        {# Image/placeholder du plat #}
        <div class="rounded-lg w-36 bg-gray-200 h-36"></div>

        {# Contenu texte simulé à droite de l’image #}
        <div class="flex flex-col justify-around px-4 leading-normal gap-2">

            {# Nom du plat / titre #}
            <div class="text-base tracking-tight bg-gray-300 h-8 rounded-lg"></div>

            {# Liste des groupes alimentaires (FGP) #}
            <div class="list-fgp flex flex-row gap-2">
                <div class="w-3 h-3 rounded-lg bg-gray-200"></div>
            </div>

            {# Bloc de détails / informations supplémentaires #}
            <div class="flex flex-col items-start mb-2 gap-2">

                {# Ligne avec deux petits blocs (ex: quantités, calories) #}
                <div class="flex flex-row gap-2">
                    <div class="w-16 h-11 rounded-lg bg-gray-300"></div>
                    <div class="w-20 h-11 rounded-lg bg-gray-300"></div>
                </div>

                {# Boutons simulés #}
                <div class="flex items-center gap-2 mt-2">
                    <button type="button" class="rounded-lg bg-gray-300 w-22 h-10"></button>
                    <button type="button" class="rounded-lg bg-gray-300 w-20 h-4"></button>
                </div>

            </div>

        </div>

    </div>

</div>