<!DOCTYPE html>
<html lang="fr" class="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    {# Meta tags dynamiques #}
    <meta name="description" content="{% block meta_description %}fc-nutrition.com{% endblock %}">
    <meta name="keywords" content="{% block meta_keywords %}nutrition, bilan, santé{% endblock %}">
    <meta name="author" content="fc-nutrition">

    {# Favicon #}
    <link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">

    {# Fonts Google #}
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700;900&family=Archivo+Black&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {# Stylesheets principaux #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">
    {% endblock %}

    <title>{% block title %}fc-nutrition.com{% endblock %}</title>
</head>

<body class="font-sans antialiased">

    {# Header (optionnel selon la route) #}
    {% if app.request.attributes.get('_route') not in routes_without_header_nav %}
        {{ include('navigation/header.html.twig') }}
    {% endif %}

    {# Alertes flash messages #}
    {{ include('partials/alert/alert.html.twig') }}

    {# Contenu principal #}
    <main>
        {% block body %}{% endblock %}
    </main>

    {# Footer (optionnel selon la route) #}
    {% if app.request.attributes.get('_route') not in routes_without_header_nav %}
        {{ include('partials/_footer.html.twig') }}
    {% endif %}

    {# Scripts JS #}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}

        {# FOSJsRouting #}
        <script src="{{ asset('bundles/fosjsrouting/js/router.min.js') }}"></script>
        <script src="{{ path('fos_js_routing_js', { callback: 'fos.Router.setData' }) }}"></script>

        {# Bootstrap 5 bundle avec Popper #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>

        {# Tailwind Elements ou autres modules #}
        <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
    {% endblock %}

</body>
</html>
