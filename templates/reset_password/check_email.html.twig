{% extends "security/_layout.html.twig" %}

{% block content %}

    <div class="flex flex-col gap-2">

        {# Message d'information expliquant que si un compte existe, un email de réinitialisation a été envoyé #}
        <p class="mt-4 text-left leading-relaxed">
            Si un compte correspondant à votre adresse e-mail existe, un e-mail vient de vous être envoyé contenant un lien que vous pouvez utiliser pour réinitialiser votre mot de passe.
            <br />
            {# Affichage de la durée de validité du lien de réinitialisation fournie par le ResetPasswordBundle #}
            Ce lien expirera dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
        </p>

        {# Lien permettant à l'utilisateur de revenir à la page de connexion #}
        <a href="{{ path('app_login') }}" class="text-sky-600 hover:text-sky-700 transition duration-300 font-semibold">Revenir à la connexion</a>

    </div>

{% endblock %}