{# Conteneur principal du bloc de contenu #}
<div class="content bg-white p-6 rounded-2xl shadow-balanced">

    {# Titre affichant la période sélectionnée #}
    <h1 class="text-xl md:text-2xl xl:text-3xl mb-4">
        Votre évolution sur la période du {{ start|date('d/m/Y') }} au {{ end|date('d/m/Y') }}
    </h1>

    {# Bloc réservé à l'insertion des graphiques, défini dans les sous-templates #}
    {% block chart %}{% endblock %}

</div>