{% extends "security/_layout.html.twig" %}

{% form_theme registerForm _self %}

{% block title %}S'inscrire{% endblock %}

{% block content %}

    {{ form_start(registerForm, {'attr' : {'novalidate' : 'novalidate'}}) }}

        {{ form_errors(registerForm) }}

        <h1 class="font-bold text-xl">
            S'inscrire
        </h1>

        <div class="mt-2 text-gray-500 text-sm">
            Encore quelques clics pour vous connecter à votre compte !
        </div>
        
        <div class="mt-8 form-group text-sm">

            <div class="mb-2">

                {{ form_label(registerForm.email) }}

                <span class="text-red-500">{{ form_errors(registerForm.email) }}</span>

                {{ form_widget(registerForm.email) }}

            </div>

            <div class="mb-2">

                {{ form_label(registerForm.username) }}

                <span class="text-red-500">{{ form_errors(registerForm.username) }}</span>

                {{ form_widget(registerForm.username) }}

            </div>

            <div class="mb-2">

                {{ form_label(registerForm.country) }}

                <span class="text-red-500">{{ form_errors(registerForm.country) }}</span>

                {{ form_widget(registerForm.country) }}

            </div>

            <div class="mt-6">

                {{ form_label(registerForm.plainPassword) }}

                <span class="text-red-500">{{ form_errors(registerForm.plainPassword) }}</span>
       
                <div data-controller="password-visibility" class="relative flex items-center">

                    {{ form_widget(registerForm.plainPassword, {'id': 'psw'}) }}

                    {{ include('partials/_button_visibility_pwd.html.twig') }}

                </div>

            </div>

        </div>

        <div class="flex flex-col mt-6 text-sm">

            <span class="text-red-500">{{ form_errors(registerForm.terms) }}</span>

            <div class="flex flex-row gap-1">

                <div>
                    {{ form_widget(registerForm.terms) }}
                </div>

                <div class="mt-1">
                    {{ form_label(registerForm.terms) }}
                </div>

            </div>

        </div>

        <div class="button-group text-center mt-4">

            <button type="submit" class="bg-sky-600 hover:bg-sky-700 text-white w-full font-bold p-2 text-base cursor-pointer rounded-lg transition duration-300">Valider</button>
            
            <div class="mt-5 text-sm">Déja inscrit? <br><a href="{{ path('app_login') }}" class="text-sky-600 hover:text-sky-700 text-sm">Identifiez-vous</a></div>
        
        </div>

        <div class="mt-7 text-gray-700 dark:text-gray-600 text-center text-sm">

			En vous inscrivant, vous acceptez nos
			<br>

			<a class="text-sky-600 hover:text-sky-700" href="{{ path('app_terms') }}">Termes et Conditions</a>

		</div>

    {{ form_end(registerForm) }}

{% endblock %}