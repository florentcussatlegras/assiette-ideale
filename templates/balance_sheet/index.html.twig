{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - Mes bilans {# Titre de la page : héritage du titre parent + "Mes bilans" #}
{% endblock %}

{% block body %}

    <div class="py-12">

        {# En-tête de la page avec titre #}
        {{ include('navigation/_header_page.html.twig', {title: 'Mes bilans'}) }}

        <div class="my-4">

            {# Conteneur principal avec controllers Stimulus #}
            <div 
                {{ stimulus_controller(
                    'balance-sheet', 
                    { 
                        urlLoadContent: path('app_balance_sheet_show_average_data'),
                        urlLoadFavoriteDish: path('app_balance_sheet_favorite_item', {type: 'dish'}),
                        urlLoadFavoriteFood: path('app_balance_sheet_favorite_item', {type: 'food'}),
                        urlLoadMostCaloricMeal: path('app_balance_sheet_most_caloric_meal') 
                    } 
                ) 
                | stimulus_controller('alert-meal-modal') 
                }} 
                class="flex flex-col"
            >

                {# Sélecteur de période (date picker) #}
                {{ include('balance_sheet/_datepicker_range.html.twig') }}

                {# Conteneur principal : colonne gauche (bilans) + colonne droite (favoris) #}
                <div class="flex flex-col 2xl:flex-row w-full lg:w-10-12 gap-2 2xl:gap-4 mt-6">

                    {# Colonne gauche : contenu principal (bilans journaliers/moyennes) #}
                    <div class="w-full 2xl:w-4/5 mb-2">

                        {# Zone où le contenu des bilans sera injecté dynamiquement via Stimulus #}
                        <div class="content bg-white px-6 rounded-xl shadow-balanced" data-balance-sheet-target="content"></div>

                        {# Loader / skeleton pendant le chargement des bilans #}
                        <div data-balance-sheet-target="loader">
                            {{ include("balance_sheet/_card_content_skeleton.html.twig") }}
                        </div>

                    </div>

                    {# Colonne droite : favoris de l'utilisateur (plat, aliment, repas calorique) #}
                    <div class="w-full 2xl:w-1/5 mt-0">

                        <div class="flex flex-col gap-2 items-start font-medium bg-white p-4 rounded-xl shadow-balanced" data-balance-sheet-target="contentFavorite">

                            {# Plat favori #}
                            <span class="text-base">Votre plat favori</span>
                            <div data-balance-sheet-target="favoriteDish">
                                {{ render(path('app_balance_sheet_favorite_item', {type: 'dish'})) }}
                            </div>

                            {# Aliment favori #}
                            <span class="text-base">Votre aliment favori</span>
                            <div data-balance-sheet-target="favoriteFood">
                                {{ render(path('app_balance_sheet_favorite_item', {type: 'food'})) }}
                            </div>

                            {# Repas le plus calorique #}
                            <span class="text-base">Votre repas le plus calorique</span>
                            <div data-balance-sheet-target="mostCaloricMeal">
                                {{ render(path('app_balance_sheet_most_caloric_meal')) }}
                            </div>

                        </div>

                        {# Loader / skeleton pour les favoris pendant le chargement #}
                        <div class="flex my-2 h-[200px] items-center justify-center hidden" data-balance-sheet-target="loaderFavorite">
                            {{ include("balance_sheet/_card_favorites_skeleton.html.twig") }}
                        </div>

                    </div>

                </div> {# Fin du conteneur principal (bilans + favoris) #}

            </div> {# Fin du conteneur Stimulus principal #}

        </div> {# Fin du wrapper de contenu #}

    </div> {# Fin du padding principal py-12 #}

{% endblock %}