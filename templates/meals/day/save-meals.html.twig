{% if app.session.get('_meal_day_date') != 'model' and (lastRankMeal > 0 or (lastRankMeal == 0 and 'dishAndFoods' in app.session.get('_meal_day_' ~ lastRankMeal)|keys and app.session.get('_meal_day_' ~ lastRankMeal)['dishAndFoods'] is not empty)) %}

    <div class="flex items-center gap-3 ml-auto justify-end mb-6">

        <button
            type="button" 
            class="remove-meals p-2 flex items-center font-bold gap-2 px-2 py-2 md:px-4 md:py-4 text-base rounded-lg cursor-pointer current-shadow bg-gray-200 text-sky-600 hover:text-sky-700 transition duration-300"
            data-action="meal#removeMeals"
            data-url="{{ path('meal_day_remove') }}"
            data-url-redirect="{{ path('meal_day') }}"
        >
                Supprimer
        </button>

        <button 
            type="button" 
            class="save-meals font-bold bg-sky-600 hover:bg-sky-700 flex items-center gap-2 px-2 py-2 md:px-4 md:py-4 xl:py-3 shadow-lg text-white rounded-lg text-base cursor-pointer transition duration-300"
            data-action="meal#saveMeals"
            data-url="{{ path('menu_add') }}"
        >
            Enregistrer
        </button>

    </div>

{% elseif app.session.get('_meal_day_date') == 'model' and 'dishAndFoods' in app.session.get('_meal_day_0')|keys and app.session.get('_meal_day_0')['dishAndFoods'] is not empty %}

    <form action="{{ path('model_meal_add', {'meal_list' : true}) }}" method="POST" class="flex w-full justify-end items-center gap-4 mb-4 md:mb-12">

        <input type="hidden" class="rank" name="rankMeal" value="0">
        
        <div class="input-group flex">

            <input type="text" class="name-model-meal form-control ml-auto h-12 rounded-lg w-[250px] text-xl" name="name" placeholder="Nom du repas" required="required">
        
        </div>
        
        <button 
            type="submit" 
            class="save-meals font-bold bg-light-blue flex items-center gap-2 px-4 py-3 current-shadow text-white rounded-lg text-lg" 
        >

            <svg class="flex md:my-hidden" width="20px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill-rule="evenodd" clip-rule="evenodd" d="M18.1716 1C18.702 1 19.2107 1.21071 19.5858 1.58579L22.4142 4.41421C22.7893 4.78929 23 5.29799 23 5.82843V20C23 21.6569 21.6569 23 20 23H4C2.34315 23 1 21.6569 1 20V4C1 2.34315 2.34315 1 4 1H18.1716ZM4 3C3.44772 3 3 3.44772 3 4V20C3 20.5523 3.44772 21 4 21L5 21L5 15C5 13.3431 6.34315 12 8 12L16 12C17.6569 12 19 13.3431 19 15V21H20C20.5523 21 21 20.5523 21 20V6.82843C21 6.29799 20.7893 5.78929 20.4142 5.41421L18.5858 3.58579C18.2107 3.21071 17.702 3 17.1716 3H17V5C17 6.65685 15.6569 8 14 8H10C8.34315 8 7 6.65685 7 5V3H4ZM17 21V15C17 14.4477 16.5523 14 16 14L8 14C7.44772 14 7 14.4477 7 15L7 21L17 21ZM9 3H15V5C15 5.55228 14.5523 6 14 6H10C9.44772 6 9 5.55228 9 5V3Z" fill="#FFFFFF"></path> </g></svg>
            
            <span class="my-hidden md:flex text-white">Enregistrer</span>

        </button>
        
    </form>

{% endif %}
