<!-- MODAL ENERGY ALERT -->
<div
    id="alert-energy-modal"
    data-popover-info-target="background"
    class="fixed inset-0 z-50 hidden bg-black/80 flex items-start justify-center transition-opacity duration-200 pt-4"
>
    {# Conteneur principal du modal #}
    <div class="w-full max-w-xl p-4">

        {# Conteneur interne du modal, transform/opacity pour animation #}
        <div
            data-popover-info-target="container"
            class="bg-white shadow-lg overflow-hidden hidden transform transition-all duration-300 scale-95 opacity-0 rounded-lg"
        >
            <!-- Header du modal -->
            <div class="flex items-center justify-end text-light-blue p-4">

                {# Bouton de fermeture du modal #}
                <button
                    type="button"
                    data-action="click->popover-info#hide"
                    class="flex items-center justify-center rounded-full hover:bg-gray-100 transition duration-300 p-3"
                >
                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 14 14">
                        <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                </button>

            </div>

            <!-- Body du modal -->
            <div class="p-5 min-h-32">

                {# Loader affiché pendant la récupération AJAX des données #}
                <div data-popover-info-target="loader" class="hidden w-full h-24 flex items-center justify-center">
                    <div class="loader"></div>
                </div>

                {# Contenu injecté dynamiquement via AJAX #}
                <div data-popover-info-target="content" class="hidden text-base px-4"></div>

            </div>

            <!-- Footer du modal -->
            <div class="p-5 rounded-b-3xl flex justify-end">
                {# Bouton de confirmation / fermeture #}
                <button
                    data-action="click->popover-info#hide"
                    class="bg-light-blue text-white font-bold rounded-lg px-6 py-2.5 text-lg shadow hover:bg-blue-600 transition"
                >
                    OK
                </button>
            </div>

        </div> {# Fin du conteneur interne du modal #}

    </div> {# Fin du conteneur principal du modal #}
</div> {# Fin du modal energy alert #}