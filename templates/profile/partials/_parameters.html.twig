<div class="flex items-center">

    {# Bloc photo de profil avec prévisualisation et upload #}
    <div class="w-2/5 flex justify-center">
        <div class="flex flex-col justify-center">

            {# Conteneur de l'image circulaire #}
            <div class="w-20 h-20 sm:w-24 sm:h-24 flex-none lg:w-32 lg:h-32 image-fit relative">

                {# Affiche la photo de l'utilisateur si elle existe, sinon une image par défaut #}
                {% if profileForm.pictureFile.vars.value is not empty %}
                    <img id="user_profil_picture_preview" class="rounded-full" 
                         alt="Photo de l'utilisateur {{ app.user.username }}" 
                         src="{{ app.user.picturePath|imagine_filter('squared_thumbnail_medium') }}">
                {% else %}
                    <img id="user_profil_picture_preview" class="rounded-full" 
                         src="{{ asset('svg/user.svg') }}">
                    </img>
                {% endif %}

                {# Bouton caméra pour modifier la photo #}
                <div class="absolute mb-1 mr-1 flex items-center justify-center bottom-0 right-0 bg-theme-17 rounded-full p-2 cursor-pointer">
                    <i class="w-4 h-4 text-white" data-feather="camera"></i>
                </div>

                {# Champ de formulaire caché pour uploader la nouvelle image #}
                {{ form_widget(profileForm.pictureFile, {'attr' : {'class' : 'absolute bottom-0 right-0 h-12 w-10 opacity-0 rounded-full'}}) }}

            </div>

            {# Affiche les erreurs liées au champ photo #}
            {{ form_errors(profileForm.pictureFile) }}
        </div>
    </div>

    {# Bloc informations utilisateur : nom d'utilisateur et email #}
    <div class="w-3/5 flex flex-col gap-4 pr-10">
        {{ form_row(profileForm.username) }}
        {{ form_row(profileForm.email) }}
    </div>

    {# Token CSRF du formulaire #}
    {{ form_widget(profileForm._token_profile) }}

</div>