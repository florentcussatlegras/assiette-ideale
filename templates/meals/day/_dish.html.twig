{# Vérifie si le plat/aliment est déjà sélectionné dans le repas #}
{% if currentMeal is not null and currentMeal.dishAndFoods[rankDish] is defined %}
    {% set selectedItem = currentMeal.dishAndFoods[rankDish] %}
{% else %}
    {% set selectedItem = null %}
{% endif %}

{# Recherche dans l'analyse des items si cet aliment/plat possède des restrictions #}
{% set itemCheck = itemAnalysis|filter(a => a.id == item.id)|first %}

{# Détermine si l'item est interdit (true si des raisons existent) #}
{% set forbidden = itemCheck ? true : false %}

{# Conteneur principal du plat/aliment #}
{# Si l'item est interdit et que l'utilisateur n'a pas l'autorisation de le sélectionner,
   on applique une opacité pour indiquer visuellement qu'il est désactivé #}
<div class="wrapper-dishOrFood flex flex-col w-full py-8 px-4 relative rounded-2xl shadow-soft bg-white {% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}opacity-60{% endif %}">

	{# Badge indiquant qu'un aliment ou plat est interdit par les restrictions personnelles #}
	{% if forbidden %}
		<div class="absolute relative group top-2 right-2 bg-red-500 text-white text-xs px-2 py-1 rounded cursor-pointer">

			{# Texte affiché sur le badge #}
			Interdit par vos restrictions personnelles

			{# Info-bulle affichée au survol du badge #}
			{# Elle liste les raisons exactes de l'interdiction #}
			<div class="absolute right-0 top-full mb-2 p-4
									bg-black text-white text-sm rounded
									opacity-0 group-hover:opacity-100
									transition duration-200 whitespace-nowrap pointer-events-none"
									style="z-index: 60">

				{# Parcours des raisons d'interdiction #}
				{% for r in itemCheck.reasons %}

					{# Cas : aliment interdit par un régime alimentaire #}
					{% if r.type == 'diet' or r.type == 'diet_group' %}
						Le {{ r.food }} est interdit par le régime {{ r.source }}.

					{# Cas : aliment explicitement interdit par l'utilisateur #}
					{% elseif r.type == 'user_forbidden_food' %}
						L'{{ r.source }} est un aliment que vous avez choisi de ne pas consommer.
					{% endif %}

					<br>
				{% endfor %}
			</div>
		</div>
	{% endif %}
	
	{# Détermine le type de l’item (Dish ou Food) #}
	{% set type = item.item_type %}

	{# Badge d’alerte affiché seulement si ce n’est pas un modèle de repas #}
	{% if app.session.get('_meal_day_date') != 'model' %}
		<div id="alerts-{{ type }}-{{ item.id }}" class="alerts absolute -top-2 -left-2">

			{# Appel au contrôleur qui génère les alertes nutritionnelles éventuelles #}
			{{ render(controller("App\\Controller\\meal\\AlertController::show", {
				'class' : type,
				'dishOrFoodId' : item.id,
				'isSelected' : false
			})) }}

		</div>
	{% endif %}

	{# Ligne principale : image + informations à droite #}
	<div class="flex flex-row items-center md:flex-row md:max-w-xl p-2 bg-white">

		{# Affiche l’ID de l’item seulement en environnement de développement #}
		{% if app.environment == "dev" %}
			{{ item.id }}
		{% endif %}

		{# Image du plat ou aliment, placeholder sinon #}
		{% if item.picture is not null %}
			<img alt="Image" class="rounded-lg w-36"
				src="{{ (type|lower ~ '/' ~ item.picture)|imagine_filter('squared_thumbnail_small') }}">
		{% else %}
			<img src="https://placehold.co/144x144" alt="Photo plat" width="144px" class="rounded-lg">
		{% endif %}

		{# Bloc texte à droite de l’image #}
		<div class="flex flex-col justify-around px-4 leading-normal gap-2">

			{# Nom du plat ou aliment avec lien vers sa page détail #}
			<a class="dish-or-food-name tracking-tight hover:text-sky-700"
			   {% if type == 'Dish' %}
				   href="{{ path('app_dish_show', { id: item.id, slug: item.slug }) }}"
			   {% else %}
				   href="{{ path('app_food_show', { slug: item.slug }) }}"
			   {% endif %}
			   role="option">

				{# Mise en évidence du mot-clé recherché dans le nom #}
				{{ showKeyword(item.name, keyword)|raw }}

			</a>

			{# Liste des groupes alimentaires parents (FGP) avec leurs couleurs #}
			{% if type == 'Dish' %}
				{{ include('dish/_list_fgp_colors.html.twig', { dish: item }) }}
			{% else %}
				<div class="list-fgp flex flex-row gap-2">
					<div class="w-3 h-3 rounded-lg"
						 style="border: 1px solid {{ item.parent_color }};
						 background-color: {{ item.parent_color }}">
					</div>
				</div>
			{% endif %}

			{# Bloc des quantités et unités de mesure #}
			<div id="containerQuantity-{{ item.id }}"
				 class="flex flex-col items-start mb-2 font-normal text-gray-700 text-base dark:text-gray-400 gap-2"
				 data-url-get-unitmeasure-alias="{{ path('meal_get_unitmeasure_alias') }}">

				<div>

					{% if type == 'Dish' %}

						{# Sélecteur du nombre de portions pour un plat #}
						<select 
							class="n-portion quantity-{{ item.id }} text-center w-16 h-11 rounded-lg"
							name="quantity"
							data-item-type="{{ type }}"
							data-dish-id="{{ item.id }}"
							data-rank-meal="{{ rankMeal }}"
							data-rank-dish="{{ rankDish }}"

							{# Désactivation si l'item est interdit et que l'utilisateur ne peut pas le sélectionner #}
							{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
								disabled
							{% endif %}
						>

							{% for i in range(1,20) %}
								<option value="{{ i }}"
									{% if selectedItem != null and selectedItem.id == item.id and selectedItem.quantity == i %}
										selected
									{% elseif i == 1 %}
										selected
									{% endif %}
								>
									{{ i }}
								</option>
							{% endfor %}

						</select>

						{# Texte indiquant l'unité (portion) #}
						<span name="unitMeasure" class="w-20 text-sm">portion(s)</span>

						{# Champ caché utilisé pour stocker l'unité de mesure côté JS #}
						<input type="hidden"
							   name="unitMeasure"
							   class="unit-measure unitMeasure-{{ item.id }}"
							   value="95"/>

					{% else %}

						{# Champ de saisie de quantité pour un aliment #}
						<input
							type="number"
							class="quantity-food quantity-{{ item.id }} w-16 h-11 rounded-lg"
							name="quantity"
							data-item-type="{{ type }}"
							data-food-id="{{ item.id }}"
							data-rank-meal="{{ rankMeal }}"
							data-rank-dish="{{ rankDish }}"
							value="{% if selectedItem != null and selectedItem.id == item.id %}{{ selectedItem.quantity }}{% endif %}"

							{# Désactivation si interdit #}
							{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
								disabled
							{% endif %}
						>

						{# Détermination de l'unité sélectionnée par défaut #}
						{% set selectedId = "86" %}
						{% set ids = item.unit_measure_ids|split(',') %}

						{% if selectedItem != null and selectedItem.id == item.id %}
							{% for i in 0..(ids|length - 1) %}
								{% if selectedItem.unitMeasure == ids[i]|trim %}
									{% set selectedId = ids[i]|trim %}
								{% endif %}
							{% endfor %}
						{% endif %}

						{# Sélecteur d’unités de mesure pour l’aliment #}
						<select
							name="unitMeasure"
							class="unit-measure select2 unitMeasure-{{ item.id }} w-16 h-11 rounded-lg"
							data-food-id="{{ item.id }}"
							data-rank-meal="{{ rankMeal }}"
							data-rank-dish="{{ rankDish }}"

							{# Désactivation si interdit #}
							{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
								disabled
							{% endif %}
						>

							{% if item.unit_measure_ids is not empty %}
								{% for i in 0..(ids|length - 1) %}
									{% set optionId = ids[i]|trim %}

									<option value="{{ optionId }}"
											name="optionUnitMeasure"
											{% if optionId == selectedId %}selected{% endif %}>
										{{ unitMeasures[optionId] }}
									</option>

								{% endfor %}
							{% endif %}

						</select>

					{% endif %}

				</div>

				{# Boutons Ajouter / Annuler pour gérer la sélection dans le repas #}
				<div class="flex items-center gap-2 mt-2">

					<button
						type="button"
						style="z-index: 0"
						class="rounded-lg text-white bg-sky-600 px-4 py-2
						{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
							opacity-60 cursor-not-allowed
						{% endif %}"

						{# Choix de l'action Stimulus selon le mode (ajout ou modification) #}
						{% if update is same as(false) %}
							data-action="sidebar-list-dishes#addItem"
						{% else %}
							data-action="sidebar-list-dishes#updateItem"
						{% endif %}

						data-item-id="{{ item.id }}"
						data-item-type="{{ type }}"
						data-rank-meal="{{ rankMeal }}"
						data-rank-dish="{{ rankDish }}"
						data-url-add-preselect-item="{{ path('meal_sidebar_preselect_item', { id: item.id, type: type }) }}"

						{# Désactivation si interdit #}
						{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
							disabled
						{% endif %}
					>
						Ajouter
					</button>

					<button
						type="button"
						class="text-sky-600"
						data-action="sidebar-list-dishes#resetSelection"
						data-item-id="{{ item.id }}"
						data-item-type="{{ type }}"

						{# Désactivation si interdit #}
						{% if forbidden and app.user.canSelectForbiddenItems is same as(false) %}
							disabled
						{% endif %}
					>
						Annuler
					</button>

				</div>

			</div>

		</div>

	</div>

</div>