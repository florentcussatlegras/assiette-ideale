{# Vérifie si la liste des repas modèles est vide #}
{% if modelMeals is empty %}

    {# Message affiché si aucun repas n'est disponible #}
    <div class="flex items-center justify-center text-gray-500" style="height: 240px">
        Aucun repas
    </div>

{% else %}

    {# Conteneur principal avec le contrôleur Stimulus pour l'accordéon des repas #}
    <div {{ stimulus_controller('menu-accordion') }}>

        {# Affiche le nombre total de repas #}
        <div class="flex items-center gap-3 mb-8">
            <span class="badge text-lg">
                {{ modelMeals|length }} {{ 'meals.count'|trans({ '%count%': modelMeals|length }, "meal") }}
            </span>
        </div>

        {# Boucle sur chaque repas modèle #}
        {% for modelMeal in modelMeals %}

            {# Carte représentant un repas modèle cliquable #}
            <div
                class="card-model-meal flex flex-col items-center mb-2 bg-white rounded-2xl shadow-balanced p-4 cursor-pointer transition-colors"
                data-action="click->model-meal-select#toggleSelect"
                data-model-meal-select-target="card"
                data-meal-id="{{ modelMeal.id }}"
            >

                <div class="w-full flex flex-row items-center justify-between">

                    {# Partie gauche : type du repas et nom #}
                    <div class="flex flex-col w-1/4 flex-wrap">
                        {% if modelMeal.type is not null %}
                            <span class="text-neutral-500 text-base" data-model-meal-select-target="typeName">
                                {{ modelMeal.type.frontName }}
                            </span>
                        {% endif %}
                        <h1 class="text-base uppercase leading-4 mb-0" data-model-meal-select-target="name">
                            {{ modelMeal.name }}
                        </h1>
                        {# Indique si le repas contient gluten/lactose #}
                        {{ render(path('model_meal_have_gluten_lactose', {idModelMeal: modelMeal.id})) }}
                    </div>

                    {# Liste des groupes alimentaires (affiché sur grand écran) #}
                    <div class="my-hidden lg:flex flex-row gap-2">
                        {{ render(controller("App\\Controller\\meal\\ModelController::getListFgp", { 'id': modelMeal.id })) }}
                    </div>

                    {# Affichage de l'énergie totale du repas #}
                    <div class="flex items-center bg-gray-400 text-white text-sm font-bold px-2 py-1 rounded-full">
                        {{ render(controller("App\\Controller\\meal\\DefaultController::getEnergy", { 'id': modelMeal.id })) }}
                    </div>

                    {# Boutons d'édition et de suppression du repas modèle #}
                    <div class="flex items-center">

                        {# Bouton modifier #}
                        <button
                            type="button"
                            {{ stimulus_controller('ripple') }}
                            class="mr-2 mt-0 btn-edit-model-meal rounded-full p-2 bg-gray-100 hover:bg-gray-200 transition duration-300"
                            data-action="click->model-meal-select#ignore click->model-meal-select#redirect click->ripple#ripple"
                            data-href="{{ path('model_meal_edit', {'idMealModel': modelMeal.id}) }}"
                        >
                            {# Icône modifier #}
                            <svg viewBox="0 0 24 24" class="text-gray-500 w-6 h-6" fill="none" xmlns="http://www.w3.org/2000/svg">
                                ...
                            </svg>
                        </button>

                        {# Bouton supprimer #}
                        <button
                            type="button"
                            {{ stimulus_controller('ripple') }}
                            data-action="click->model-meal#onRemoveMeal click->model-meal-select#ignore click->ripple#ripple"
                            class="mr-2 mt-0 btn-remove-model-meal rounded-full p-2 bg-gray-100 hover:bg-gray-200 transition duration-300"
                            data-model-meal-id="{{ modelMeal.id }}"
                            data-csrf="{{ csrf_token('delete_meal_' ~ modelMeal.id) }}"
                        >
                            {{ include("partials/svg/remove.html.twig") }}
                        </button>

                    </div>

                    {# Bouton pour ouvrir/fermer l'accordéon du détail du repas #}
                    <button type="button"
                        class="ml-4"
                        data-action="click->menu-accordion#toggle click->model-meal-select#ignore"
                        data-day="{{ modelMeal.id }}-{{ loop.index0 }}">
                        {# Flèches haut/bas #}
                        <svg data-menu-accordion-target="arrowDown" data-day-arrow="{{ modelMeal.id }}-{{ loop.index0 }}" ...></svg>
                        <svg data-menu-accordion-target="arrowUp" data-day-arrow="{{ modelMeal.id }}-{{ loop.index0 }}" class="my-hidden" ...></svg>
                    </button>

                </div>

                {# Détail du repas : liste des plats et aliments #}
                <ul 
                    id="list-model-meal-{{ modelMeal.id }}-{{ loop.index0 }}" 
                    class="text-sm w-full overflow-hidden max-h-0 transition-[max-height] duration-300" 
                    data-menu-accordion-target="panel"
                    data-day-panel="{{ modelMeal.id }}-{{ loop.index0 }}"
                >

                    {% for dishAndFood in modelMeal.dishAndFoods %}

                        <li class="flex gap-2 w-auto mb-2 items-center px-4 {% if loop.first %}mt-4{% endif %}">								

                            {% if dishAndFood['type'] == 'Dish' %}
                                {% set element = object(dishAndFood['id'], 'App\\Entity\\Dish') %}
                                {# Affichage plat #}
                                <div class="flex flex-col md:flex-row md:items-center md:gap-4 mr-6">
                                    <span class="flex flex-row items-center gap-2">
                                        {{ include('meals/model/_picture_element.html.twig') }}
                                        <a href="{{ path('app_dish_show', {'id' : element.id, 'slug' : element.slug}) }}" class="text-sky-600 text-sm leading-4 font-semibold">
                                            {{ element.name }}
                                        </a>
                                    </span>
                                    <span class="text-neutral-500 text-sm ml-8 md:ml-2">{{ dishAndFood['quantity'] }} portion{% if dishAndFood['quantity'] > 1 %}s{% endif %}</span>
                                </div>

                            {% else %}
                                {% set element = object(dishAndFood['id'], 'App\\Entity\\Food') %}
                                {# Affichage aliment #}
                                <div class="flex flex-col md:flex-row md:items-center md:gap-4 mr-6">
                                    <span class="flex flex-row items-center gap-2">
                                        {{ include('meals/model/_picture_element.html.twig') }}
                                        <a href="{{ path('app_food_show', {'slug' : element.slug}) }}" class="text-sky-600 text-sm leading-4 font-semibold">
                                            {{ element.name }}
                                        </a>
                                    </span>
                                    <span class="text-neutral-500 text-sm ml-8 md:ml-2">{{ dishAndFood['quantity'] }} {{ object(dishAndFood.unitMeasure, 'App\\Entity\\UnitMeasure').alias }}</span>
                                </div>

                            {% endif %}

                        </li>
                    
                    {% endfor %}

                </ul>

            </div>

        {% endfor %}

    </div>

{% endif %}