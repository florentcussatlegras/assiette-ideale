{# Balance sheet element chart : affiche la liste des éléments et leurs graphiques associés #}
<div class="flex flex-col xl:flex-row gap-4 items-start justify-start w-full">

    {# Colonne gauche : liste des éléments nutritionnels avec leurs alertes éventuelles #}
    <div class="w-full xl:w-[500px] min-w-0">

        {# Parcours de tous les éléments avec leur quantité #}
        {% for key, quantity in elements %}

            {# Conteneur de chaque élément #}
            <div class="flex flex-col items-start py-1 w-full">
            
                {# Vérifie si cet élément a une alerte associée #}
                {% if key in alerts|keys %}
                    {% set levelAlert = alerts[key] %}
                    
                    {# Ligne principale : label + quantité + icône d’alerte #}
                    <div class="flex flex-col gap-2 md:gap-0 md:flex-row items-start md:items-center w-full xl-w-500 justify-between">
                        <div class="flex items-center gap-2 w-full">
                            
                            {# Cercle coloré indiquant l’élément (couleur en fonction du type) #}
                            <div class="w-4 h-4 rounded-full mr-2" style="background-color: colors[key] }}"></div>
                            
                            {# Label de l’élément, avec capitalisation #}
                            <label class="w-42 md:w-48 mb-0 font-normal">
                                {{ labels[key]|capitalize }}
                            </label>

                            {# Quantité de l’élément, stylisée selon la couleur de l’alerte #}
                            <div class="flex justify-end md:justify-center w-auto md:w-28 ml-auto text-sm md:text-xl mr-0 md:mr-16">
                                <span class="bg-gray rounded-full px-2 py-1 font-semibold" style="color: {{ levelAlert.color }}">
                                    {{ quantity }} g
                                </span>
                            </div>
                        </div>

                        {# Icône d’alerte et bouton pour afficher les détails de l’alerte #}
                        <div class="flex gap-2 items-center ml-auto" style="color: {{ levelAlert.color }}">
                            <div class="relative">
                                {# Icône de warning incluse depuis un fichier séparé #}
                                {{ include('balance_sheet/_icon_warning.html.twig', { size: 7 }) }}
                            </div>
                            {# Bouton pour afficher/cacher le détail de l’alerte #}
                            <button class="p-2 rounded-full hover:bg-gray-100 duration-300 transition">
                                <svg data-balance-sheet-target="showDetailsAlert" class="show-details-alert w-6 h-6 text-slate-400 cursor-pointer" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    {# Détails de l’alerte : affichés seulement après clic sur le bouton #}
                    <div data-balance-sheet-target="detailsAlert" class="details-alert hidden text-sm" style="color: {{ levelAlert.color }}">
                        {# Contenu chargé dynamiquement via une route #}
                        {{ render(path(details_route, { key_param: key, 'quantity': quantity, 'alertCode': levelAlert.code })) }}
                    </div>

                {% endif %}

            </div>

        {% endfor %}

    </div>

    {# Colonne droite : graphiques correspondants aux éléments, chargés via controller #}
    {% for chartData in charts %}
        <div class="{{ chartData.mobile_class }} flex w-full md:w-1/2 justify-center h-64 mt-{{ chartData.mt }}">
            {{ render(controller('App\\Controller\\BalanceSheet\\ModalChartController::chart', chartData.params)) }}
        </div>
    {% endfor %}

</div>