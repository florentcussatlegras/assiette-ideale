<div 
    data-modal-form-profile-target="modal" 
    data-action="click->modal-form-profile#closeIfOutside" 
    id="weight-modal" 
    class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden"
>
    {# Conteneur du modal centré #}
    <div class="bg-white px-6 pt-8 rounded shadow-lg max-w-xl text-center relative">
        
        {# Bouton de fermeture en haut à droite #}
        <button 
            data-action="modal-form-profile#close" 
            class="absolute top-4 right-4 text-xl hover:bg-gray-100 transition duration-300 p-3 rounded-full font-bold"
        >
            <svg class="w-5 h-5 text-sky-600" fill="none" viewbox="0 0 14 14" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"></path>
            </svg>
        </button>

        {# Contenu du modal où le formulaire de poids est injecté via Symfony render(path()) #}
        <div data-modal-form-profile-target="content" class="py-6">
            {{ render(path('app_embedded_profile_edit', {'element': 'weight'})) }}
        </div>

    </div>
</div>