{# Champs cachés pour transmettre les dates de début et de fin sélectionnées #}
<input id="startFromWeekMenu" type="hidden" value="{{ start|default(null) }}" />
<input id="endFromWeekMenu" type="hidden" value="{{ end|default(null) }}" />

<div class="font-medium text-center relative text-sm">

    {# Conteneur principal des onglets et du formulaire de sélection de dates #}
    <div class="flex flex-col xl:flex-row tabs-date-range items-start xl:items-center gap-2">

        {# Formulaire manuel pour saisir la plage de dates #}
        <form class="flex flex-col md:flex-row items-start md:items-center gap-2">

            {# Label "Du" pour la date de début #}
            <div class="flex items-center mr-2 h-full">Du</div>

            {# Input date de début avec icône calendrier #}
            <div class="relative">
                <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none px-3">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                </div>
                <input
                    id="startDate"
                    name="start" 
                    type="text" 
                    class="pl-10 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full ps-10 p-2.5" 
                    placeholder="Date de départ"
                    data-evolution-target="start"
                    style="height: 40px"
                >
            </div>

            {# Label "au" pour la date de fin #}
            <div class="flex items-center mr-2 h-full">au</div>

            {# Input date de fin avec icône calendrier #}
            <div class="relative">
                <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none px-3">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                </div>
                <input
                    id="endDate"
                    name="end" 
                    type="text" 
                    class="pl-10 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full ps-10 p-2.5"
                    style="height: 40px"
                    placeholder="Date de fin"
                    data-evolution-target="end"
                >
            </div>
            
            {# Bouton pour valider la sélection manuelle des dates #}
            <button 
                type="button" 
                class="btn border px-2 py-4 ml-0 md:ml-4 bg-sky-600 text-white font-semibold text-sm rounded-lg"
                style="height: 40px"
                data-action="evolution#setDates"
            >
                Valider
            </button>

        </form>

        {# Boutons rapides pour sélectionner des plages de dates prédéfinies #}
        <div class="flex flex-col gap-2 md:flex-row w-full items-stretch xl:ml-12">

            {# Hier #}
            <button
                class="inline-block px-4 py-3 font-semibold tabs-date-range_tab bg-gray-100 text-gray-900 text-sm lg:text-lg leading-4 rounded-lg hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                data-action="click->evolution#setDates"
                data-start="{{ "-1 day"|date('Y-m-d') }}"
                data-end="{{ "-1 day"|date('Y-m-d') }}"
            >
                Hier
            </button>

            {# La dernière semaine #}
            <button 
                class="inline-block px-4 py-3 font-semibold tabs-date-range_tab bg-gray-100 text-gray-900 text-sm lg:text-lg leading-4 rounded-lg hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                data-action="click->evolution#setDates"
                data-start="{{ "-1 week"|date('Y-m-d') }}"
                data-end="{{ "now"|date('Y-m-d') }}"
            >
                La dernière semaine
            </button>

            {# Les 15 derniers jours #}
            <button
                class="inline-block px-4 py-3 font-semibold tabs-date-range_tab bg-gray-100 text-gray-900 text-sm lg:text-lg leading-4 rounded-lg hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                data-action="click->evolution#setDates"
                data-start="{{ "-2 weeks"|date('Y-m-d') }}"
                data-end="{{ "now"|date('Y-m-d') }}"
            >
                Les 15 derniers jours
            </button>

            {# Le dernier mois #}
            <button 
                class="inline-block px-4 py-3 font-semibold tabs-date-range_tab bg-gray-100 text-gray-900 text-sm lg:text-lg leading-4 rounded-lg hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                aria-current="page"
                data-action="click->evolution#setDates"
                data-start="{{ "-1 month"|date('Y-m-d') }}"
                data-end="{{ "now"|date('Y-m-d') }}"
            >
                Le dernier mois
            </button>

            {# La dernière année #}
            <button
                class="inline-block px-4 py-3 font-semibold tabs-date-range_tab bg-gray-100 text-gray-900 text-sm lg:text-lg leading-4 rounded-lg hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                data-action="click->evolution#setDates"
                data-evolution-target="defaultDate"
                data-start="{{ "-1 year"|date('Y-m-d') }}"
                data-end="{{ "yesterday"|date('Y-m-d') }}"
            >
                La dernière année
            </button>

        </div>
    </div>

    {# Barre de sélection active animée sous les onglets de dates #}
    <div class="tabs-date-range_smart-bar w-0 bg-light-blue" style="height:2px"></div>

</div>