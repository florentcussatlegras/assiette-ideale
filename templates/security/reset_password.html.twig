{% extends "base.html.twig" %}

{% form_theme resetForm "form/_custom_profile_themes.html.twig" %}

{% block body %}

    <main role="main">

        {{ include('partials/_header.html.twig', { h1_content: 'Reinitialisation de votre mot de passe' }) }}

        <center class="mt-16 p-5 mx-auto w-full md:w-2/3 xl:w-1/2 bg-white">

            {{ form_start(resetForm, {'novalidate' : 'novalidate', 'attr': {'class': 'my-10'}}) }}

                {{ form_widget(resetForm) }}

                <div class="button-group mt-7 flex justify-center items-center gap-6">

                    <a href="{{ path('app_login') }}" class="text-light-blue font-bold">
                        Annuler
                    </a>

                    <button class="bg-light-blue text-white font-bold px-2 py-2 rounded-lg">
                        Valider
                    </button>
                    
                </div>

            {{ form_end(resetForm) }}

        </center>

    </main>

{% endblock %}
