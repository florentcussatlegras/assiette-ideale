{% extends "base.html.twig" %}

{% block body %}

    {# Conteneur principal couvrant toute la largeur et hauteur, avec fond coloré et centrage du contenu #}
    <div class="flex h-full w-full items-center justify-center bg-sky-600 md:bg-white relative">

        {# Carte centrale contenant le formulaire ou contenu spécifique à la page #}
        <div class="flex items-center mx-auto w-full md:w-1/2 xl:w-1/3 p-8 rounded-none md:rounded-2xl bg-sky-600 shadow-none md:shadow-medium">

            {# Logo cliquable centré pour mobile (masqué sur desktop) #}
            <a href="{{ path('app_homepage') }}" class="absolute top-4 left-1/2 -translate-x-1/4 p-3 flex md:my-hidden items-center">
                <div class="flex flex-row font-bold cursor-pointer text-white text-4xl">
                    <div>Assiette&nbsp;</div>
                    <div>idé<span class="text-lime-600">a</span>le</div>
                </div>
            </a>

            {# Logo cliquable positionné en haut à gauche pour desktop (masqué sur mobile) #}
            <a href="{{ path('app_homepage') }}" class="absolute top-4 left-4 p-3 my-hidden md:flex items-center">
                <div class="flex flex-row font-bold cursor-pointer text-white text-4xl">
                    <div>Assiette&nbsp;</div>
                    <div>idé<span class="text-lime-600">a</span>le</div>
                </div>
            </a>

            {# Conteneur pour le contenu spécifique de la page (formulaire, texte, etc.) #}
            <div class="flex flex-col w-full justify-center items-center">

                    {% block content %}{% endblock %}

            </div>

        </div>

    </div>

{% endblock %}