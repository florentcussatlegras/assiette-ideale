<section class="flex flex-col items-center w-full lg:flex-row md:mx-auto gap-4 md:px-16 xl:px-18 pb-10 md:pb-20 bg-white xl:max-w-[1100px] 2xl:max-w-[1536px] mx-auto">

  {# Titre principal et sous-titre de la section #}
  <div class="text-center mb-4 md:mb-12">
    <span class="text-sky-600 uppercase font-semibold text-xs leading-3 tracking-widest">
      deux formules pour maîtriser votre alimentation
    </span>
    <h2 class="text-2xl md:text-4xl xl:text-6xl font-bold">
      Saisissez vos repas, suivez vos bilans et 
      <span class="text-sky-600">atteignez vos objectifs</span> plus facilement
    </h2>
  </div>

  {# Conteneur principal des deux formules (Essentiel et Premium) #}
  <div class="flex flex-col md:flex-row gap-8">
    
    {# Formule Essentiel #}
    <div class="flex-1 bg-white rounded-xl shadow-lg p-8 flex flex-col text-[#39434D] font-medium">
      
      {# Titre de la formule Essentiel #}
      <h3 class="text-2xl font-bold mb-4 text-yellow-400">🌱 Essentiel</h3>

      {# Description principale de la formule #}
      <p class="bg-yellow-400 text-white p-4 rounded-xl text-xl">
        Utilisez nos outils pour gérer plus facilement vos menus.
      </p>

      {# Liste des fonctionnalités de la formule Essentiel #}
      <ul class="flex flex-col gap-3 mb-6 mt-6 pt-6 border-t border-gray-200">

        {# Fonctionnalité 1 : saisie facile des menus #}
        <li class="flex items-center gap-3">
            <span class="flex items-center justify-center w-10 h-8 flex-shrink-0">
                {# Icône représentant un menu #}
                <svg class="text-yellow-400" fill="currentColor" ...></svg>
            </span>
            <span>Saisissez facilement <span class="text-yellow-400">vos menus au quotidien</span></span>
        </li>

        {# Fonctionnalité 2 : bilan nutritionnel clair #}
        <li class="flex items-center gap-3">
            <span class="flex items-center justify-center w-10 h-8 flex-shrink-0">
                {# Icône représentant un bilan nutritionnel #}
                <svg class="w-8 h-8 text-yellow-400" ...></svg>
            </span>
            <span>Obtenez un <span class="text-yellow-400">bilan clair de vos apports et de votre équilibre nutritionnel</span></span>
        </li>

        {# Fonctionnalité 3 : suivi de l’évolution #}
        <li class="flex items-start gap-3">
            <span class="flex items-center justify-center w-10 h-8 flex-shrink-0">
                {# Icône représentant une courbe ou évolution #}
                <svg class="w-7 h-7 text-yellow-400" ...></svg>
            </span>
            <span>Suivez <span class="text-yellow-400">votre évolution</span> dans le temps et <span class="text-yellow-400">visualisez vos progrès</span></span>
        </li>

        {# Fonctionnalité 4 : points à améliorer #}
        <li class="flex items-start gap-3">
            <span class="flex items-center justify-center w-10 h-8 flex-shrink-0">
                {# Icône représentant un check ou validation #}
                <svg class="w-6 h-6 text-yellow-400" ...></svg>
            </span>
            <span>Identifiez <span class="text-yellow-400">les points à améliorer</span></span>
        </li>

      </ul>

      {# Note complémentaire sur la gratuité #}
      <p class="text-gray-400 italic mt-4">… le tout 100% gratuit !</p>
    </div>

    {# Formule Premium #}
    <div class="flex-1 rounded-xl shadow-lg p-8 flex flex-col">

      {# Titre de la formule Premium #}
      <h3 class="text-2xl font-bold mb-4 text-sky-700">🚀 Premium</h3>

      {# Description principale de la formule Premium #}
      <p class="bg-sky-600 text-white p-4 rounded-xl text-xl">Optimisation et réajustements</p>

      {# Liste des fonctionnalités de la formule Premium #}
      <ul class="flex flex-col gap-3 mb-6 mt-6 pt-6 border-t border-gray-200 font-medium text-[#39434D]">

        {# Fonctionnalité 1 : inclut toutes les fonctionnalités de l’Essentiel #}
        <li class="flex items-center gap-3">
          <span class="flex items-center justify-center w-8 h-8 flex-shrink-0 text-sky-700 mt-1">
            {# Icône check #}
            <svg class="w-6 h-6 text-sky-600" ...></svg>
          </span>
          <span class="text-sky-600">Toutes les fonctionnalités de l’Essentiel</span>
        </li>

        {# Fonctionnalité 2 : ajustements automatiques des besoins énergétiques #}
        <li class="flex items-center gap-3">
          <span class="flex items-center justify-center w-7 h-7 flex-shrink-0">
            {# Icône réglages énergie #}
            <svg fill="#2E6FC1" ...></svg>
          </span>
          <span><span class="text-sky-600">Ajustements automatiques</span> de vos besoins énergétiques</span>
        </li>

        {# Fonctionnalité 3 : assistant personnel pour conseils #}
        <li class="flex items-center gap-3">
          <span class="flex items-center justify-center w-8 h-8 flex-shrink-0">
            {# Icône assistant #}
            <svg xmlns="http://www.w3.org/2000/svg" ...></svg>
          </span>
          <span>Bénéficiez d'<span class="text-sky-600">un assistant personnel</span> pour vous conseiller via téléphone, email et chat</span>
        </li>

        {# Fonctionnalité 4 : suivi précis du poids et de l’IMC #}
        <li class="flex items-center gap-3">
          <span class="flex items-center justify-center w-8 h-8 flex-shrink-0">
            {# Icône contrôle poids #}
            <svg fill="#2E6FC1" class="w-6 h-6" ...></svg>
          </span>
          <span><span class="text-sky-600">Contrôle précis et cadré</span> de votre <span class="text-sky-600">poids</span> et de votre <span class="text-sky-600">IMC</span></span>
        </li>

      </ul>

      {# Note complémentaire sur l’accompagnement Premium #}
      <p class="text-gray-500 italic mt-4">… pour un accompagnement complet et des résultats durables.</p>
    </div>

  </div>
</section>