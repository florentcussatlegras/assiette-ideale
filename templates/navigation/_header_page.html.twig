{# Vérifie si l'utilisateur est connecté #}
{% if is_granted('IS_AUTHENTICATED') %}

    {# Conteneur du header avec breadcrumb + titre #}
    <div class="flex flex-col text-base">

        {# Ligne contenant le fil d'Ariane (breadcrumb) + le titre de section #}
        <div class="flex flex-row items-center gap-2">

            {# Breadcrumb vers le dashboard (ex: Mon espace > ...) #}
            {{ include('navigation/_breadcrumb_dashboard.html.twig')  }}

            {# Titre de la page passé en variable #}
            {{ title }}

        </div>

        {# Titre principal de la page #}
        <h1 class="text-2xl md:text-4xl font-bold">
            {{ include('navigation/_title.html.twig') }}
        </h1>

    </div>

{% else %}

    {# Si l'utilisateur n'est pas connecté → affichage du titre seulement #}
    <h1 class="text-2xl md:text-4xl font-bold">
        {{ include('navigation/_title.html.twig') }}
    </h1>

{% endif %}