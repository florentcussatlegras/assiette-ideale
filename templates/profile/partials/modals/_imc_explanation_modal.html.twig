{# Modal pour l'explication de l'IMC (Indice de Masse Corporelle) #}
<div
    data-imc-explanation-modal-target="modal"
    class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center z-50 hidden text-gray-700"
>
    {# Conteneur principal du modal #}
    <div class="bg-white px-6 pt-8 pb-6 rounded shadow-lg max-w-4xl w-full relative">

        {# Bouton pour fermer le modal #}
        <button data-action="imc-explanation-modal#close" class="absolute top-4 right-4 text-xl text-sky-600 hover:bg-gray-100 rounded-full p-3 transition duration-300 font-bold">
            <svg class="w-5 h-5 text-sky-600" fill="none" viewbox="0 0 14 14" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"></path>
            </svg>
        </button>

        {# Titre du modal #}
        <h2 class="text-xl font-bold mb-4">
            L' IMC
        </h2>

        {# Loader affiché pendant le chargement du contenu #}
        <div 
            data-imc-explanation-modal-target="loader"
            class="hidden flex justify-center items-center py-12"
        >
            <div class="w-10 h-10 border-4 border-sky-300 border-t-sky-600 rounded-full animate-spin"></div>
        </div>

        {# Contenu dynamique du modal, injecté via Stimulus ou JS #}
        <div data-imc-explanation-modal-target="content" class="font-normal text-base my-8"></div>

    </div>
</div>