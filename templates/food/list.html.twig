{% extends "base.html.twig" %}

{% block title %}
    {{ parent() }} - Les aliments
{% endblock %}

{% block body %}

    {# Conteneur principal avec stimulus controller pour rechargement dynamique #}
    <div
        {{ stimulus_controller('reload-content', {
            url: path('app_food_list') 
        }) }}
        class="py-12"
    >

        {# Formulaire pour gérer la sélection d’aliments #}
        <form action="{{ app.session.get('route_referer') }}" method="POST">
        
            {# Si on vient d’un plat spécifique, on récupère le nom du groupe alimentaire pour le sous-titre #}
            {% if app.session.has('recipe_dish') is same as(true) %}
                {% set subtitle = app.request.query.get('fg')|foodgroupnameFromId %}
            {% endif %}

            {# Header avec titre de la page #}
            {{ include('navigation/_header_page.html.twig', {title: 'Les aliments'}) }}
            
            <div>

                <div class="flex flex-col gap-2">

                    {# Barre de recherche d’aliment #}
                    <div class="relative search_dish_list w-full md:w-1/3 mb-2">
                        <input
                            id="input_search_food_list"
                            name="q"
                            placeholder="Saisissez le nom d'un aliment..."
                            type="search"
                            class="block p-6 w-full rounded-lg"
                            data-reload-content-target="search"
                            data-action="reload-content#onSearchInput"
                        >
                        {# Bouton pour effacer la recherche, caché par défaut #}
                        <button
                            type="button"
                            class="absolute right-4 top-3 text-gray-400 hover:text-gray-700 text-xl hidden"
                            data-reload-content-target="clearButton"
                            data-action="reload-content#clearSearch"
                        >
                            ✕
                        </button>
                    </div>
                        
                    {# Boutons pour sélectionner/désélectionner tous les groupes alimentaires #}
                    <div class="flex flex-row gap-2 items-center">

                        {% if app.session.has('recipe_dish') is same as(false) %}
                            <button
                                type="button"
                                data-action="reload-content#onSelectAllFoodGroup"
                                data-reload-content-target="selectAllFoodGroup"
                                {% if app.request.query.get('unique_fg') %}
                                    class="flex items-center justify-center px-4 py-3 gap-2 text-sm lg:text-lg leading-4 rounded-lg text-gray-900 bg-gray-100 hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                                {% else %}
                                    class="flex items-center justify-center px-4 py-3 gap-2 text-sm lg:text-lg leading-4 rounded-lg text-white bg-sky-600 hover:bg-sky-600 transition duration-300 hover:text-white"
                                {% endif %}
                            >
                                <span>Tous les groupes</span>
                            </button>
                            <button 
                                type="button" 
                                data-action="reload-content#onDeselectAllFoodGroup"
                                data-reload-content-target="deselectAllFoodGroup"
                                class="flex items-center justify-center px-4 py-3 gap-2 text-sm lg:text-lg leading-4 rounded-lg bg-gray-100 text-gray-900 hover:bg-gray-200 transition duration-300 hover:text-gray-900"
                            >
                                <span>Aucun groupe</span>
                            </button>
                        {% endif %}
                    
                        {# Inclusion des filtres gluten/lactose #}
                        {{ include('meals/partials/_button_gluten_lactose.html.twig') }}
                    
                    </div>

                    {# Liste des groupes alimentaires affichée ou cachée selon la session #}
                    <div class="flex flex-row items-center flex-wrap mt-2 gap-2 {% if app.session.has('recipe_dish') is same as(false) %}visible{% else %}invisible absolute{% endif %}">
                        {{ include('/foodgroup/_foodgroup_list.html.twig') }}
                    </div>

                </div>
                
                {# Token CSRF pour la sécurité du formulaire #}
                <input type="hidden" name="_token" value="{{ csrf_token('select_foods') }}" />

                {# Si un groupe alimentaire est présent dans la requête, l’inclure en hidden #}
                {% if app.request.query.has('fg') %}
                    <input type="hidden" name="fg" value="{{ app.request.query.get('fg') }}" />
                {% endif %}

                {# Conteneur pour le switch de vue (liste / grille) #}
                <div class="flex flex-col items-start lg:flex-row mt-2 mb-2 md:items-center md:justify-between gap-2 w-full">

                    <div class="hidden lg:flex h-8 md:h-10 xl:h-11 ml-0 md:ml-auto">
                        {# Inclusion du switch mode d’affichage #}
                        {{ include('partials/_view_mode_list.html.twig') }}
                    </div>

                </div>

                {# Affichage des erreurs liées aux quantités d’aliments dans un plat #}
                {% if app.session.has('food_error_quantity') %}
                    <div class="text-red-700 mt-4">
                        {{ render(controller('App\\Controller\\DishController::showErrorFoodQuantity')) }}
                    </div>
                {% endif %}

                {# Conteneur principal des aliments #}
                <div 
                    id="wrapper" 
                    class="wrapper gap-4 mt-8 min-h-64 relative" 
                    data-loading="addClass(opacity-50)"
                    data-reload-content-target="content"
                >
                    {{ include('food/_food_list.html.twig') }}
                </div>

                {# Skeleton loader pendant le chargement des aliments #}
                <div 
                    class="wrapper gap-4 mt-8 relative hidden"
                    data-reload-content-target="loader"
                >
                    {% for i in 1..12 %}
                        {{ include('food/_food_skeleton.html.twig') }}
                    {% endfor %}
                </div>

                {# Bouton “Voir plus d’aliments” pour charger dynamiquement #}
                <center class="mt-8 mb-8">
                    <button 
                        type="button"
                        class="bg-gray-200 hover:bg-gray-300 px-4 py-2 h-10 text-sm rounded-lg text-gray-500 hover:text-gray-900 transition duration-300"
                        data-action="reload-content#onLoadMore"
                        data-reload-content-target="loadMore"
                    >
                        Voir plus d'aliments...
                    </button>
                </center>

                {# Script pour switcher entre vue liste et grille #}
                <script> 
                    const wrapper = document.getElementById("wrapper");
                    const btnModeList = document.getElementById("view-mode-list");
                    const btnModeGrid = document.getElementById("view-mode-grid");
                    
                    btnModeList.addEventListener("click", function (event) {
                        // Passage en vue liste
                        event.preventDefault();
                        wrapper.classList.add("list");
                        btnModeGrid.classList.remove("view-mode-switch__display--selected")
                        this.classList.add("view-mode-switch__display--selected");
                    });

                    btnModeGrid.addEventListener("click", function (event) {
                        // Passage en vue grille
                        event.preventDefault();
                        wrapper.classList.remove("list");
                        btnModeList.classList.remove("view-mode-switch__display--selected");
                        this.classList.add("view-mode-switch__display--selected");
                    });
                </script>

            </div>

            {# Menu fixe pour ajouter les aliments au plat si on est dans la session recipe_dish #}
            {% if app.session.has('recipe_dish') is same as(true) %}
                <div id="menu" class="fixed bottom-0 right-0 mb-10 mr-4 flex items-center gap-4 p-4 z-50 top-auto left-auto">
                    <button type="submit" class="py-2 px-4 rounded-lg font-bold flex items-center gap-2 current-shadow bg-light-blue text-white text-lg hover:bg-sky-700 transition duration-300">
                        <svg viewBox="0 0 24 24" class="w-12 h-12" fill="#ffffff">
                            <path d="M17,13H13V17H11V13H7V11H11V7H13V11H17M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"></path>
                        </svg>
                        <span class="hidden md:inline-block">Ajouter les aliments au plat</span>
                    </button>
                </div>
            {% endif %}

        </form>

    </div>

{% endblock %}