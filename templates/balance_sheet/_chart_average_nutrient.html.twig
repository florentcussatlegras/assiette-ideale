{# Conteneur pour un graphique des quantités de nutriments par période avec son titre #}

<div class="flex flex-col items-center">

    {# Rendu du graphique côté serveur (Chart.js ou autre via Twig) #}
    {{ render_chart(chart) }}

    {# Titre du graphique sous le graphique, responsive selon la taille d’écran #}
    <span class="md:mt-2 text-sm md:text-base font-semibold text-center">
        {{ title }}
    </span>

</div>
