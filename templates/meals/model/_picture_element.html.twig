{% if element.picture is not null and element.picturePath is not null %}
    {# Affiche la vraie image si disponible #}
    <img 
        src="{{ element.picturePath|imagine_filter('squared_thumbnail_small') }}" 
        alt="pic-{{ element.slug }}" 
        class="rounded-lg w-6"
    >
{% else %}
    {# Image de remplacement si aucune photo #}
    <img 
        src="https://placehold.co/20x20" 
        alt="Photo plat" 
        class="rounded-lg w-6"
    >
{% endif %}